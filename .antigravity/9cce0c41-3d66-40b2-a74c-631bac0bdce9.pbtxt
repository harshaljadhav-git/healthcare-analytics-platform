        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "## \360\237\224\221 Pre-Configured Console Access Credentials"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "PulseStream features full **Role-Based Access Control (RBAC)**. Log in as any of the following users to explore custom dashboards and data pools tailored to their corporate mandates:"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "| Username | Password | Role / Access Levels | Use Cases Covered |"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "| :--- | :--- | :--- | :--- |"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "| **`admin`** | `admin123` | **Admin** / Full Control | Configuration of simulator speed (Pause, Live, 10x, 50x), manual burst generation, database wipes and seed resets. |"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "| **`doctor`** | `doctor123` | **Doctor** / Clinician Board | Roster logs, doctor patient counts, card files, and ward booking utilisation charts. |"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "| **`analyst`** | `analyst123` | **Analyst** / Data Platform | Bronze/Silver/Gold analytics, ready-to-run PySpark templates, and interactive SQL testing sandbox. |"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "| **`finance`** | `finance123` | **Finance** / Chief Auditor | Insurer claim payouts charts, CFO transactional registers, and billing segment summaries.|"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "---"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "## \360\237\220\263 Running Under Docker & Local Setup"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "### Prerequisite Environment"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "- Docker and Docker Compose installed."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "### Quick Start Inbound Commands:"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "To build and run the entire suite in a micro-container, execute:"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "```bash"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "# 1. Boot up the PulseStream container group"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "docker compose up --build -d"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "# 2. Verify container logs are active"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "docker compose logs -f"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "# 3. Check application wellness probe"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "curl http://localhost:3000/health"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "```"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Now, navigate to **`http://localhost:3000`** in any web browser to access the active management console."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "---"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "## \360\237\223\212 Medallion Table Schemas & Lake Exporters"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "PulseStream exposes direct, high-performance CSV and JSON endpoints suitable for `spark.read` imports or cron ingestion workers:"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "| Inbound Stream | Target Schema Fields | Excel/CSV Ingress URL | JSON Raw Stream URL |"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "| :--- | :--- | :--- | :--- |"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "| **Patients** | `id`, `name`, `age`, `gender`, `bloodGroup`, `city`, `state`, `registrationDate`, `insuranceProvider`, `category` | `/api/export/csv/patients` | `/api/export/json/patients` |"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "| **Appointments** | `id`, `patientId`, `doctorId`, `department`, `appointmentDate`, `duration`, `status`, `revenueGenerated` | `/api/export/csv/appointments` | `/api/export/json/appointments` |"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "| **Doctors** | `id`, `name`, `department`, `experience`, `consultationFee`, `utilization` | `/api/export/csv/doctors` | `/api/export/json/doctors` |"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "| **Transactions** | `id`, `patientId`, `appointmentId`, `date`, `amount`, `type`, `insuranceCoverage`, `paymentType`, `department` | `/api/export/csv/transactions` | `/api/export/json/transactions` |"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "---"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "## \360\237\247\261 Real Databricks PySpark Loaders"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Copy and paste this production-ready PySpark script into a Databricks Notebook to stream and backfill raw CSV tuples directly into your **Delta Lake Bronze Layer**:"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "```python"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "# Create automated ingestion wrapper for PulseStream lakes"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "ingress_base_url = \"http://YOUR_DEPLOYED_CONTAINER_IP:3000/api/export/csv/\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "tables = [\"patients\", \"appointments\", \"doctors\", \"transactions\"]"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "for table in tables:"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    # Read live csv stream"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    raw_df = spark.read \\"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .format(\"csv\") \\"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .option(\"header\", \"true\") \\"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .option(\"inferSchema\", \"true\") \\"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .load(f\"{ingress_base_url}{table}\")"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    # Append load into Databricks Delta Lakehouses (Bronze Stage)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    raw_df.write \\"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .format(\"delta\") \\"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .mode(\"append\") \\"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .save(f\"/mnt/pulse_healthcare/bronze/{table}\")"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "print(\"\342\234\205 Inbound Delta Append-Batch Execution Complete.\")"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "```"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "---"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "## \360\237\233\241\357\270\217 Observability and Prometheus Integration"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "The platform includes active standard metrics exporting endpoint at **`/metrics`** to integrate with downstream Prometheus scrapers and Grafana."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Try loading the raw telemetry data:"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "```bash"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "curl http://localhost:3000/metrics"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "```"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
      }
    }
