    instruction: "Refactor AppoinmentsPanel list layout to match the technical theme constraints."
    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"space-y-6\">\n      \n      {/* Header and Counters */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4\">\n        <div>\n          <h2 className=\"text-xl font-bold tracking-tight text-slate-900\">Synthetic Ingress Register: Appointments</h2>\n          <p className=\"text-xs text-slate-500 mt-0.5\">\n            Real-time appointment schedule, consultation durations, and checkin completions.\n          </p>\n        </div>\n        \n        {/* Total appointments */}\n        <div className=\"bg-white shrink-0 shadow-sm border border-slate-100 rounded-xl px-4 py-2 flex items-center gap-3\">\n          <div className=\"p-2 bg-emerald-50 rounded-lg text-emerald-500 font-bold font-mono\">\n            <Calendar className=\"h-4 w-4 shrink-0\" />\n          </div>\n          <div>\n            <span className=\"text-[10px] text-slate-400 font-mono block uppercase\">Total Lake Size</span>\n            <span className=\"text-base font-bold font-mono text-slate-800\">{total.toLocaleString()} Records</span>\n          </div>\n        </div>\n      </div>\n\n      {/* Query Filters */}\n      <div className=\"bg-white p-4 rounded-xl border border-slate-100 shadow-sm flex flex-wrap gap-2.5 items-center justify-between\">\n        <div className=\"flex flex-wrap items-center gap-2.5\">\n          \n          {/* Status filter */}\n          <select\n            value={selectedStatus}\n            onChange={(e) => {\n              setSelectedStatus(e.target.value);\n              setPage(1);\n            }}\n            className=\"px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-xs text-slate-600/80 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 transition-all font-medium\"\n          >\n            <option value=\"\">All Appointment Statuses</option>\n            <option value=\"Completed\">Completed</option>\n            <option value=\"Scheduled\">Scheduled</option>\n            <option value=\"Cancelled\">Cancelled</option>\n            <option value=\"Rescheduled\">Rescheduled</option>\n          </select>\n\n          {/* Department Selection */}\n          <select\n            value={selectedDepartment}\n            onChange={(e) => {\n              setSelectedDepartment(e.target.value);\n              setPage(1);\n            }}\n            className=\"px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-xs text-slate-600/80 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 transition-all font-medium\"\n          >\n            <option value=\"\">All Departments</option>\n            {departments.map((dept) => (\n              <option key={dept} value={dept}>{dept}</option>\n            ))}\n          </select>\n        </div>\n\n        <button\n          type=\"button\"\n          onClick={() => {\n            setSelectedStatus(\'\');\n            setSelectedDepartment(\'\');\n            setPage(1);\n          }}\n          className=\"p-2 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-xl text-slate-500 hover:text-slate-700 transition flex items-center gap-1.5 text-xs font-semibold\"\n          title=\"Clear configuration filters\"\n        >\n          <RefreshCw className=\"h-3.5 w-3.5 shrink-0 animate-hover\" />\n          Reset Filters\n        </button>\n      </div>\n\n      {/* Grid Table */}\n      <div className=\"bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden\">\n        <div className=\"overflow-x-auto\">\n          <table className=\"w-full text-left border-collapse\">\n            <thead>\n              <tr className=\"bg-slate-50 border-b border-slate-100\">\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Appointment ID</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Patient ID</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Doctor ID</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Clinical Ward</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Consulation Fee</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Duration</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Registration Date</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Schedule Status</th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-slate-50 text-slate-700 text-xs font-mono\">\n              {loading ? (\n                <tr>\n                  <td colSpan={8} className=\"text-center py-10 font-mono text-slate-400\">\n                    Executing DB Query...\n                  </td>\n                </tr>\n              ) : appointments.length === 0 ? (\n                <tr>\n                  <td colSpan={8} className=\"text-center py-10 text-slate-440\">\n                    No active synthetic database tuples match your filtration rules.\n                  </td>\n                </tr>\n              ) : (\n                appointments.map((ap) => (\n                  <tr key={ap.id} className=\"hover:bg-slate-50/50 transition-all\">\n                    <td className=\"px-5 py-3 text-slate-900 font-bold font-mono text-xs\">{ap.id}</td>\n                    <td className=\"px-5 py-3 font-medium text-blue-600 hover:underline cursor-pointer\">{ap.patientId}</td>\n                    <td className=\"px-5 py-3 font-semibold text-slate-800\">{ap.doctorId}</td>\n                    <td className=\"px-5 py-3 font-sans font-semibold text-slate-700\">{ap.department}</td>\n                    <td className=\"px-5 py-3 text-slate-900 font-semibold\">\n                      {ap.revenueGenerated > 0 ? `$${ap.revenueGenerated}` : \'$0 (Unpaid)\'}\n                    </td>\n                    <td className=\"px-5 py-3 font-sans text-slate-600\">{ap.duration} Mins</td>\n                    <td className=\"px-5 py-3 text-slate-450 text-[11px]\">\n                      {new Date(ap.appointmentDate).toLocaleDateString()} / {new Date(ap.appointmentDate).toLocaleTimeString([], {hour: \'2-digit\', minute:\'2-digit\'})}\n                    </td>\n                    <td className=\"px-5 py-3\">\n                      <span className={`px-2 py-0.5 rounded font-bold text-[10px] flex items-center w-fit gap-1 ${\n                        ap.status === \'Completed\' ? \'bg-emerald-50 text-emerald-700\' :\n                        ap.status === \'Scheduled\' ? \'bg-indigo-50 text-indigo-700\' :\n                        ap.status === \'Cancelled\' ? \'bg-rose-50 text-rose-700\' :\n                        \'bg-amber-50 text-amber-700\'\n                      }`}>\n                        {ap.status === \'Completed\' && <CheckCircle className=\"h-3 w-3 shrink-0\" />}\n                        {ap.status === \'Scheduled\' && <Calendar className=\"h-3 w-3 shrink-0\" />}\n                        {ap.status === \'Cancelled\' && <XCircle className=\"h-3 w-3 shrink-0\" />}\n                        {ap.status === \'Rescheduled\' && <AlertTriangle className=\"h-3 w-3 shrink-0\" />}\n                        {ap.status}\n                      </span>\n                    </td>\n                  </tr>\n                ))\n              )}\n            </tbody>\n          </table>\n        </div>\n\n        {/* Pagination Console */}\n        {totalPages > 1 && (\n          <div className=\"p-4 bg-slate-50 border-t border-slate-100 flex items-center justify-between text-xs text-slate-500\">\n            <span className=\"font-mono font-medium\">\n              Showing {((page - 1) * limit) + 1} to {Math.min(page * limit, total)} of <span className=\"font-semibold text-slate-800\">{total}</span> records\n            </span>\n            <div className=\"flex items-center gap-1\">\n              <button\n                type=\"button\"\n                onClick={() => setPage(p => Math.max(p - 1, 1))}\n                disabled={page === 1}\n                className=\"p-1.5 hover:bg-slate-150 border border-slate-200 bg-white rounded-lg disabled:opacity-50 transition\"\n              >\n                <ChevronLeft className=\"h-4 w-4 text-slate-600\" />\n              </button>\n              <span className=\"px-3 py-1 font-mono font-bold text-slate-800 bg-white border border-slate-200 rounded-lg\">\n                Page {page} of {totalPages}\n              </span>\n              <button\n                type=\"button\"\n                onClick={() => setPage(p => Math.min(p + 1, totalPages))}\n                disabled={page === totalPages}\n                className=\"p-1.5 hover:bg-slate-150 border border-slate-200 bg-white rounded-lg disabled:opacity-50 transition\"\n              >\n                <ChevronRight className=\"h-4 w-4 text-slate-600\" />\n              </button>\n            </div>\n          </div>\n        )}\n      </div>"
        replacement_content: "  return (\n    <div className=\"space-y-6\">\n      \n      {/* Header and Counters */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4\">\n        <div>\n          <h2 className=\"text-xl font-black tracking-tighter text-[#141414] uppercase\">SYNTHETIC INGRESS REGISTER: APPOINTMENTS</h2>\n          <p className=\"text-[10px] font-mono text-[#141414]/60 uppercase mt-0.5\">\n            Real-time appointment schedule, consultation durations, and checkin completions.\n          </p>\n        </div>\n        \n        {/* Total appointments */}\n        <div className=\"bg-white shrink-0 shadow-none border border-[#141414] rounded-none px-4 py-2 flex items-center gap-3\">\n          <div className=\"p-2 bg-[#F0EFEC] border border-[#141414] text-[#141414] font-mono font-bold\">\n            <Calendar className=\"h-4 w-4 shrink-0 text-[#141414]\" />\n          </div>\n          <div>\n            <span className=\"text-[9px] text-[#141414]/50 font-mono block uppercase\">Total Lake Size</span>\n            <span className=\"text-sm font-black font-mono text-[#141414]\">{total.toLocaleString()} RECORDS</span>\n          </div>\n        </div>\n      </div>\n\n      {/* Query Filters */}\n      <div className=\"bg-white p-4 rounded-none border border-[#141414] shadow-none flex flex-wrap gap-2.5 items-center justify-between\">\n        <div className=\"flex flex-wrap items-center gap-2.5\">\n          \n          {/* Status filter */}\n          <select\n            value={selectedStatus}\n            onChange={(e) => {\n              setSelectedStatus(e.target.value);\n              setPage(1);\n            }}\n            className=\"px-3 py-2 bg-white border border-[#141414] rounded-none text-xs text-[#141414] focus:outline-none focus:ring-1 focus:ring-[#141414] font-mono\"\n          >\n            <option value=\"\">All Appointment Statuses</option>\n            <option value=\"Completed\">Completed</option>\n            <option value=\"Scheduled\">Scheduled</option>\n            <option value=\"Cancelled\">Cancelled</option>\n            <option value=\"Rescheduled\">Rescheduled</option>\n          </select>\n\n          {/* Department Selection */}\n          <select\n            value={selectedDepartment}\n            onChange={(e) => {\n              setSelectedDepartment(e.target.value);\n              setPage(1);\n            }}\n            className=\"px-3 py-2 bg-white border border-[#141414] rounded-none text-xs text-[#141414] focus:outline-none focus:ring-1 focus:ring-[#141414] font-mono\"\n          >\n            <option value=\"\">All Departments</option>\n            {departments.map((dept) => (\n              <option key={dept} value={dept}>{dept}</option>\n            ))}\n          </select>\n        </div>\n\n        <button\n          type=\"button\"\n          onClick={() => {\n            setSelectedStatus(\'\');\n            setSelectedDepartment(\'\');\n            setPage(1);\n          }}\n          className=\"px-3.5 py-1.5 bg-[#F0EFEC] hover:bg-[#141414] hover:text-white border border-[#141414] rounded-none text-[#141414] transition-colors cursor-pointer text-xs font-bold uppercase font-mono flex items-center gap-1.5\"\n          title=\"Clear configuration filters\"\n        >\n          <RefreshCw className=\"h-3.5 w-3.5 shrink-0\" />\n          RESET_FILTERS\n        </button>\n      </div>\n\n      {/* Grid Table */}\n      <div className=\"bg-white rounded-none border border-[#141414] shadow-none overflow-hidden\">\n        <div className=\"overflow-x-auto\">\n          <table className=\"w-full text-left border-collapse\">\n            <thead>\n              <tr className=\"bg-[#F0EFEC] border-b border-[#141414]\">\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Appointment ID</th>\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Patient ID</th>\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Doctor ID</th>\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Clinical Ward</th>\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Consultation Fee</th>\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Duration</th>\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Registration Date</th>\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Schedule Status</th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-[#141414]/15 text-[#141414] text-xs font-mono\">\n              {loading ? (\n                <tr>\n                  <td colSpan={8} className=\"text-center py-12 text-[#141414]/60\">\n                    Executing Ingress Schedule Query...\n                  </td>\n                </tr>\n              ) : appointments.length === 0 ? (\n                <tr>\n                  <td colSpan={8} className=\"text-center py-12 text-[#141414]/65\">\n                    No active synthetic database tuples match your filtration rules.\n                  </td>\n                </tr>\n              ) : (\n                appointments.map((ap) => (\n                  <tr key={ap.id} className=\"hover:bg-[#F0EFEC] transition-all border-b border-[#141414]/10\">\n                    <td className=\"px-5 py-3 text-[#141414] font-bold text-xs\">{ap.id}</td>\n                    <td className=\"px-5 py-3 font-bold text-[#0066FF] underline cursor-pointer\">{ap.patientId}</td>\n                    <td className=\"px-5 py-3 font-bold text-[#141414]\">{ap.doctorId}</td>\n                    <td className=\"px-5 py-3 font-sans font-bold text-[#141414]/85\">{ap.department}</td>\n                    <td className=\"px-5 py-3 text-[#141414] font-black\">\n                      {ap.revenueGenerated > 0 ? `$${ap.revenueGenerated}` : \'$0 (UNPAID)\'}\n                    </td>\n                    <td className=\"px-5 py-3 text-[#141414]/80\">{ap.duration} Mins</td>\n                    <td className=\"px-5 py-3 text-[#141414]/60 text-[10px]\">\n                      {new Date(ap.appointmentDate).toLocaleDateString()} / {new Date(ap.appointmentDate).toLocaleTimeString([], {hour: \'2-digit\', minute:\'2-digit\'})}\n                    </td>\n                    <td className=\"px-5 py-3\">\n                      <span className={`px-1.5 py-0.5 border border-[#141414] font-black text-[9px] uppercase flex items-center w-fit gap-1 rounded-none ${\n                        ap.status === \'Completed\' ? \'bg-[#00CC66]/20 text-[#141414]\' :\n                        ap.status === \'Scheduled\' ? \'bg-[#0033CC] text-white\' :\n                        ap.status === \'Cancelled\' ? \'bg-[#FF3300]/20 text-[#141414]\' :\n                        \'bg-[#CC6600]/20 text-[#141414]\'\n                      }`}>\n                        {ap.status === \'Completed\' && <CheckCircle className=\"h-3 w-3 shrink-0\" />}\n                        {ap.status === \'Scheduled\' && <Calendar className=\"h-3 w-3 shrink-0\" />}\n                        {ap.status === \'Cancelled\' && <XCircle className=\"h-3 w-3 shrink-0\" />}\n                        {ap.status === \'Rescheduled\' && <AlertTriangle className=\"h-3 w-3 shrink-0\" />}\n                        {ap.status}\n                      </span>\n                    </td>\n                  </tr>\n                ))\n              )}\n            </tbody>\n          </table>\n        </div>\n\n        {/* Pagination Console */}\n        {totalPages > 1 && (\n          <div className=\"p-4 bg-[#F0EFEC] border-t border-[#141414] flex items-center justify-between text-xs text-[#141414]\">\n            <span className=\"font-mono font-medium opacity-85\">\n              Showing {((page - 1) * limit) + 1} to {Math.min(page * limit, total)} of <span className=\"font-bold text-[#141414]\">{total}</span> records\n            </span>\n            <div className=\"flex items-center gap-1.5\">\n              <button\n                type=\"button\"\n                onClick={() => setPage(p => Math.max(p - 1, 1))}\n                disabled={page === 1}\n                className=\"p-1.5 hover:bg-[#141414] hover:text-white border border-[#141414] bg-white disabled:opacity-30 transition cursor-pointer\"\n              >\n                <ChevronLeft className=\"h-4 w-4\" />\n              </button>\n              <span className=\"px-3 py-1 font-mono font-bold text-[#141414] bg-white border border-[#141414]\">\n                Page {page} of {totalPages}\n              </span>\n              <button\n                type=\"button\"\n                onClick={() => setPage(p => Math.min(p + 1, totalPages))}\n                disabled={page === totalPages}\n                className=\"p-1.5 hover:bg-[#141414] hover:text-white border border-[#141414] bg-white disabled:opacity-30 transition cursor-pointer\"\n              >\n                <ChevronRight className=\"h-4 w-4\" />\n              </button>\n            </div>\n          </div>\n        )}\n      </div>"
      }
      num_matches: 1
    }
  }
}
