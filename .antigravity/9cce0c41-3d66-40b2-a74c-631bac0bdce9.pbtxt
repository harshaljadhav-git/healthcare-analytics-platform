eedChange(sp);\n                  }}\n                  className={`px-3 py-1.5 rounded-lg text-xs font-semibold font-mono uppercase tracking-wider transition-all ${\n                    simStatus?.speed === sp\n                      ? \'bg-blue-600 text-white shadow-md\'\n                      : \'text-slate-400 hover:text-slate-200 hover:bg-slate-800\'\n                  }`}\n                >\n                  {sp === \'RealTime\' ? \'1x Live\' : sp === \'Fast\' ? \'10x Speed\' : sp === \'Hyper\' ? \'50x Speed\' : \'Paused\'}\n                </button>\n              ))}\n            </div>\n\n            <button\n              onClick={onForceGenerate}\n              disabled={loading}\n              className=\"bg-slate-800 hover:bg-slate-700 active:bg-slate-650 text-slate-200 border border-slate-700 px-4 py-2 rounded-xl text-xs font-semibold font-mono tracking-wider transition-all inline-flex items-center gap-1.5\"\n            >\n              <Sparkles className=\"h-3.5 w-3.5 text-amber-500\" />\n              Pulse Stream\n            </button>\n          </div>\n        </div>\n\n        {/* Live Simulation Statistics */}\n        <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4 mt-6 pt-5 border-t border-slate-800 relative z-10\">\n          <div>\n            <span className=\"text-slate-500 text-[10px] uppercase font-mono block\">Data Gen Cadence</span>\n            <span className=\"text-sm font-bold font-mono text-slate-250 mt-1 block\">\n              {simStatus?.speed === \'Pause\' ? \'N/A\' : (simStatus?.speed === \'RealTime\' ? \'Every 5 Mins\' : simStatus?.speed === \'Fast\' ? \'Every 15 Secs\' : \'Every 4 Secs\')}\n            </span>\n          </div>\n          <div>\n            <span className=\"text-slate-500 text-[10px] uppercase font-mono block\">Last Data Inbound</span>\n            <span className=\"text-sm font-bold font-mono text-slate-250 mt-1 block\">\n              {simStatus?.lastGenerated ? new Date(simStatus.lastGenerated)