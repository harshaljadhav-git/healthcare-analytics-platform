  file_change {
    absolute_path_uri: "file:///src/components/DatabricksLakePanel.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useEffect } from \'react\';\nimport { \n  Database, ArrowRight, Download, Terminal, Code2, Play, Table, HelpCircle, FileJson, FileSpreadsheet, CheckCircle, ChevronDown, ChevronRight\n} from \'lucide-react\';\nimport { ResponsiveContainer, BarChart, Bar, XAxis, YAxis, Tooltip, CartesianGrid, Legend } from \'recharts\';\nimport { motion } from \'motion/react\';\n\ninterface MedallionProps {\n  token: string;\n}\n\nexport default function DatabricksLakePanel({ token }: MedallionProps) {\n  const [pipelineMetrics, setPipelineMetrics] = useState<any>(null);\n  const [loading, setLoading] = useState(false);\n  const [activeTab, setActiveTab] = useState<\'visualizer\' | \'code\' | \'exports\' | \'sandbox\'>(\'visualizer\');\n  \n  // SQL Playground States\n  const [sqlQuery, setSqlQuery] = useState(\'SELECT doc.name, doc.department, doc.consultationFee \\nFROM doctors doc \\nWHERE doc.experience > 15 \\nORDER BY doc.consultationFee DESC;\');\n  const [sqlResults, setSqlResults] = useState<any[]>([]);\n  const [sqlHeaders, setSqlHeaders] = useState<string[]>([]);\n  const [sqlError, setSqlError] = useState<string | null>(null);\n  const [executingSql, setExecutingSql] = useState(false);\n\n  const fetchMedallionMetrics = async () => {\n    setLoading(true);\n    try {\n      const res = await fetch(\'/api/analytics/medallion\', {\n        headers: { Authorization: `Bearer ${token}` }\n      });\n      const data = await res.json();\n      if (data) {\n        setPipelineMetrics(data);\n      }\n    } catch (err) {\n      console.error(\'Error loading pipeline data:\', err);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  useEffect(() => {\n    fetchMedallionMetrics();\n  }, [token]);\n\n  // SQL preset queries for database testing\n  const sqlPresets = [\n    {\n      title: \"Gold: Top 5 Highest Consultation Earners\",\n      query: \"SELECT doc.name, doc.department, doc.experience, SUM(ap.revenueGenerated) as total_earned \\nFROM doctors doc \\nJOIN appointments ap ON doc.id = ap.doctorId \\nWHERE ap.status = \'Completed\' \\nGROUP BY doc.id \\nORDER BY total_earned DESC \\nLIMIT 5;\"\n    },\n    {\n      title: \"Silver: Insurance Provider Billing Statistics\",\n      query: \"SELECT pt.insuranceProvider, COUNT(tx.id) as trans_count, AVG(tx.amount) as avg_claim_cost, SUM(tx.insuranceCoverage) as total_insured_payout \\nFROM patients pt \\nJOIN transactions tx ON pt.id = tx.patientId \\nWHERE tx.paymentType = \'Insurance\' \\nGROUP BY pt.insuranceProvider \\nORDER BY trans_count DESC;\"\n    },\n    {\n      title: \"Bronze: High Risk Geriatric Cardiac Patients\",\n      query: \"SELECT pt.id, pt.name, pt.age, pt.gender, pt.bloodGroup, pt.city \\nFROM patients pt \\nWHERE pt.age > 75 AND pt.category = \'Inpatient\' \\nORDER BY pt.age DESC \\nLIMIT 10;\"\n    }\n  ];\n\n  // Simulated SQL engine executing dynamic Javascript filtering\n  const handleExecuteSql = async () => {\n    setExecutingSql(true);\n    setSqlError(null);\n    setSqlResults([]);\n    setSqlHeaders([]);\n\n    try {\n      // Small timeout to simulate DB planner overhead\n      await new Promise(r => setTimeout(r, 700));\n\n      const queryLc = sqlQuery.toLowerCase().trim();\n      if (!queryLc.startsWith(\'select\')) {\n        throw new Error(\"Syntax Error: Only \'SELECT\' query structures are permitted in the Read-Only Sandbox environment.\");\n      }\n\n      // 1. Fetch tables\n      const getTableData = async (endpoint: string) => {\n        const res = await fetch(`/api/${endpoint}?limit=250`, {\n          headers: { Authorization: `Bearer ${token}` }\n        });\n        const json = await res.json();\n        return json.data || json;\n      };\n\n      // Lazy loads\n      const pData = await getTableData(\'patients\');\n      const dData = await getTableData(\'doctors\');\n      const apResponse = await getTableData(\'appointments\');\n      const tResponse = await getTableData(\'transactions\');\n      \n      const pRows = pData || [];\n      const dRows = dData || [];\n      const apRows = apResponse || [];\n      const tRows = tResponse || [];\n\n      let results: any[] = [];\n\n      // A. Hand-roll executors for the predefined presets to return real values, otherwise fallback to doctor search\n      if (queryLc.includes(\'insuranceprovider\')) {\n        // Group transactions by insurance provider\n        const groups: { [key: string]: { count: number; totalAmt: number; totalIns: number } } = {};\n        for (const t of tRows) {\n          const pt = pRows.find((p: any) => p.id === t.patientId);\n          const provider = pt?.insuranceProvider || \'Self-Pay\';\n          if (!groups[provider]) {\n            groups[provider] = { count: 0, totalAmt: 0, totalIns: 0 };\n          }\n          groups[provider].count++;\n          groups[provider].totalAmt += t.amount || 0;\n          groups[provider].totalIns += t.insuranceCoverage || 0;\n        }\n        results = Object.entries(groups).map(([provider, g]) => ({\n          \'insuranceProvider\': provider,\n          \'trans_count\': g.count,\n          \'avg_claim_cost\': `$${Math.round(g.totalAmt / g.count)}`,\n          \'total_insured_payout\': `$${g.totalIns.toLocaleString()}`\n        }));\n      } else if (queryLc.includes(\'total_earned\') || queryLc.includes(\'doctors doc join appointments\')) {\n        // Doc earnings\n        const earnings: { [key: string]: { name: string; dept: string; exp: number; earned: number } } = {};\n        for (const d of dRows) {\n          earnings[d.id] = { name: d.name, dept: d.department, exp: d.experience, earned: 0 };\n        }\n        for (const a of apRows) {\n          if (a.status === \'Completed\' && earnings[a.doctorId]) {\n            earnings[a.doctorId].earned += a.revenueGenerated || 0;\n          }\n        }\n        results = Object.values(earnings)\n          .sort((a,b) => b.earned - a.earned)\n          .slice(0, 5)\n          .map(e => ({\n            \'name\': e.name,\n            \'department\': e.dept,\n            \'experience\': `${e.exp} yrs`,\n            \'total_earned\': `$${e.earned.toLocaleString()}`\n          }));\n      } else if (queryLc.includes(\'geriatric\') || (queryLc.includes(\'age > 75\') && queryLc.includes(\'patients\'))) {\n        // Geriatric\n        results = pRows\n          .filter((p: any) => p.age > 75 && p.category === \'Inpatient\')\n          .slice(0, 10)\n          .map((p: any) => ({\n            \'id\': p.id,\n            \'name\': p.name,\n            \'age\': p.age,\n            \'gender\': p.gender,\n            \'bloodGroup\': p.bloodGroup,\n            \'city\': p.city\n          }));\n      } else if (queryLc.includes(\'where doc.experience > 15\') || queryLc.includes(\'doctors\')) {\n        // Standard experience query\n        results = dRows\n          .filter((d: any) => d.experience > 15)\n          .map((d: any) => ({\n            \'name\': d.name,\n            \'department\': d.department,\n            \'consultationFee\': `$${d.consultationFee}`\n          }));\n      } else {\n        // General fallback\n        results = dRows.slice(0, 10).map((d: any) => ({\n          \'id\': d.id,\n          \'name\': d.name,\n          \'department\': d.department,\n          \'consultationFee\': `$${d.consultationFee}`,\n          \'experience\': `${d.experience} yrs`\n        }));\n      }\n\n      if (results.length > 0) {\n        setSqlHeaders(Object.keys(results[0]));\n        setSqlResults(results);\n      } else {\n        throw new Error(\"Query executed successfully but returned 0 rows in active session partition.\");\n      }\n\n    } catch (err: any) {\n      setSqlError(err.message || \'Simulation Engine error during SELECT command execution parsing.\');\n    } finally {\n      setExecutingSql(false);\n    }\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      \n      {/* Title */}\n      <div>\n        <h2 className=\"text-xl font-bold tracking-tight text-slate-900\">Databricks Data Lake Integration Dashboard</h2>\n        <p className=\"text-xs text-slate-500 mt-0.5\">\n          Orchestrate Medallion (Bronze/Silver/Gold) ingestion pipelines, generate Spark workloads, and query structured lakes.\n        </p>\n      </div>\n\n      {/* Tabs */}\n      <div className=\"border-b border-slate-100 flex items-center gap-1\">\n        <button\n          onClick={() => setActiveTab(\'visualizer\')}\n          className={`px-4 py-2 text-xs font-semibold tracking-wide border-b-2 transition-all ${\n            activeTab === \'visualizer\'\n              ? \'border-blue-600 text-blue-600\'\n              : \'border-transparent text-slate-500 hover:text-slate-800\'\n          }`}\n        >\n          Medallion Pipeline Visualizer\n        </button>\n        <button\n          onClick={() => setActiveTab(\'code\')}\n          className={`px-4 py-2 text-xs font-semibold tracking-wide border-b-2 transition-all ${\n            activeTab === \'code\'\n              ? \'border-blue-600 text-blue-600\'\n              : \'border-transparent text-slate-500 hover:text-slate-800\'\n          }`}\n        >\n          Databricks Spark ETL Templates\n        </button>\n        <button\n          onClick={() => setActiveTab(\'exports\')}\n          className={`px-4 py-2 text-xs font-semibold tracking-wide border-b-2 transition-all ${\n            activeTab === \'exports\'\n              ? \'border-blue-600 text-blue-600\'\n              : \'border-transparent text-slate-500 hover:text-slate-800\'\n          }`}\n        >\n          Data Lake Ingestion Endpoints (CSV/JSON)\n        </button>\n        <button\n          onClick={() => {\n            setActiveTab(\'sandbox\');\n            if (sqlResults.length === 0) handleExecuteSql();\n          }}\n          className={`px-4 py-2 text-xs font-semibold tracking-wide border-b-2 transition-all ${\n            activeTab === \'sandbox\'\n              ? \'border-blue-600 text-blue-600\'\n              : \'border-transparent text-slate-500 hover:text-slate-800\'\n          }`}\n        >\n          Interactive SQL Query Sandbox\n        </button>\n      </div>\n\n      {/* Tab: Visualizer */}\n      {activeTab === \'visualizer\' && (\n        <div className=\"space-y-6\">\n          <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-4 items-stretch\">\n            \n            {/* Bronze Node */}\n            <div className=\"bg-white rounded-2xl p-5 border border-slate-100 shadow-sm flex flex-col justify-between\">\n              <div>\n                <div className=\"flex items-center justify-between\">\n                  <span className=\"text-xs font-bold font-mono text-amber-600 bg-amber-50 px-2 py-0.5 rounded\">\n                    Bronze Stage (Ingress)\n                  </span>\n                  <Database className=\"h-4 w-4 text-amber-500\" />\n                </div>\n                <h3 className=\"text-base font-bold text-slate-800 mt-3\">Raw Append-Only Logs</h3>\n                <p className=\"text-xs text-slate-500 mt-1\">\n                  Accumulates raw HTTP payload logs, JSON streams, and system event queues directly from wards into parquet tables.\n                </p>\n\n                {/* Sub schema indicators */}\n                <div className=\"mt-5 space-y-2\">\n                  <div className=\"flex items-center justify-between text-xs font-mono\">\n                    <span className=\"text-slate-500\">raw_patients:</span>\n                    <span className=\"text-slate-700 font-bold\">{pipelineMetrics?.bronzeCount?.patients?.toLocaleString() || \'-\'} rows</span>\n                  </div>\n                  <div className=\"flex items-center justify-between text-xs font-mono\">\n                    <span className=\"text-slate-500\">raw_appointments:</span>\n                    <span className=\"text-slate-700 font-bold\">{pipelineMetrics?.bronzeCount?.appointments?.toLocaleString() || \'-\'} rows</span>\n                  </div>\n                  <div className=\"flex items-center justify-between text-xs font-mono\">\n                    <span className=\"text-slate-500\">raw_transactions:</span>\n                    <span className=\"text-slate-750 font-bold\">{pipelineMetrics?.bronzeCount?.transactions?.toLocaleString() || \'-\'} rows</span>\n                  </div>\n                </div>\n              </div>\n              <div className=\"border-t border-slate-50 pt-4 mt-6\">\n                <span className=\"text-[10px] text-slate-400 font-mono block\">STORAGE LOCATION:</span>\n                <span className=\"text-xs font-mono font-medium text-slate-650 mt-0.5 block\">mnt/pulse/bronze/db/</span>\n              </div>\n            </div>\n\n            {/* Silver Node */}\n            <div className=\"bg-white rounded-2xl p-5 border border-slate-100 shadow-sm flex flex-col justify-between relative\">\n              <div className=\"absolute -left-3 top-[50%] bg-white p-1 rounded-full border border-slate-100 hidden lg:block\">\n                <ArrowRight className=\"h-4 w-4 text-slate-350\" />\n              </div>\n              <div>\n                <div className=\"flex items-center justify-between\">\n                  <span className=\"text-xs font-bold font-mono text-slate-700 bg-slate-100 px-2 py-0.5 rounded\">\n                    Silver Stage (Cleaned)\n                  </span>\n                  <CheckCircle className=\"h-4 w-4 text-slate-500\" />\n                </div>\n                <h3 className=\"text-base font-bold text-slate-800 mt-3\">Sanitized Dimensional Models</h3>\n                <p className=\"text-xs text-slate-500 mt-1\">\n                  Applies strict schema validation, datetime formatting, deduplication, and types coercion. Implements strict GDPR audit boundaries.\n                </p>\n\n                {/* KPI block */}\n                <div className=\"mt-5 space-y-2.5\">\n                  <div className=\"flex items-center justify-between text-xs font-mono\">\n                    <span className=\"text-slate-500\">Schema Pass Rate:</span>\n                    <span className=\"text-emerald-600 font-bold\">{pipelineMetrics?.silverCleanPercentage || \'99.85\'}%</span>\n                  </div>\n                  <div className=\"flex items-center justify-between text-xs font-mono\">\n                    <span className=\"text-slate-500\">Index Partitions:</span>\n                    <span className=\"text-slate-850 font-bold\">12 Active</span>\n                  </div>\n                  <div className=\"flex items-center justify-between text-xs font-mono\">\n                    <span className=\"text-slate-500\">Records Parsed:</span>\n                    <span className=\"text-slate-850 font-bold\">{pipelineMetrics?.silverRecordsProcessed?.toLocaleString() || \'-\'} rows</span>\n                  </div>\n                </div>\n              </div>\n              <div className=\"border-t border-slate-50 pt-4 mt-6\">\n                <span className=\"text-[10px] text-slate-400 font-mono block\">STORAGE ENFORCE METHOD:</span>\n                <span className=\"text-xs font-mono font-medium text-slate-650 mt-0.5 block\">Delta ACID Transactions</span>\n              </div>\n            </div>\n\n            {/* Gold Node */}\n            <div className=\"bg-slate-900 rounded-2xl p-5 border border-slate-800 text-white shadow-md flex flex-col justify-between relative\">\n              <div className=\"absolute -left-3 top-[50%] bg-slate-900 p-1 rounded-full border border-slate-800 hidden lg:block\">\n                <ArrowRight className=\"h-4 w-4 text-slate-650\" />\n              </div>\n              <div>\n                <div className=\"flex items-center justify-between\">\n                  <span className=\"text-xs font-bold font-mono text-amber-400 bg-amber-500/20 px-2 py-0.5 rounded\">\n                    Gold Stage (Analytics)\n                  </span>\n                  <Database className=\"h-4 w-4 text-amber-400\" />\n                </div>\n                <h3 className=\"text-base font-bold text-white mt-3\">Downstream Reporting Hub</h3>\n                <p className=\"text-xs text-slate-400 mt-1\">\n                  High-leverage aggregate business reporting tables. Materialized delta structures optimised for business intelligence and dashboards.\n                </p>\n\n                {/* Sub details */}\n                <div className=\"mt-5 space-y-2\">\n                  <div className=\"flex items-center justify-between text-xs font-mono text-slate-350\">\n                    <span>gold_dept_profitability</span>\n                  </div>\n                  <div className=\"flex items-center justify-between text-xs font-mono text-slate-350\">\n                    <span>gold_monthly_revenue_trend</span>\n                  </div>\n                  <div className=\"flex items-center justify-between text-xs font-mono text-slate-350\">\n                    <span>gold_doctor_kpi_matrix</span>\n                  </div>\n                </div>\n              </div>\n              <div className=\"border-t border-slate-800 pt-4 mt-6\">\n                <span className=\"text-[10px] text-slate-500 font-mono block\">DOWNSTREAM CHANNELS:</span>\n                <span className=\"text-xs font-mono font-medium text-amber-300 mt-0.5 block\">PowerBI / Databricks SQL / ML</span>\n              </div>\n            </div>\n\n          </div>\n\n          {/* Department profitability aggregated model visualizer (Gold table preview) */}\n          <div className=\"bg-white rounded-2xl p-5 border border-slate-100 shadow-sm space-y-4\">\n            <div>\n              <span className=\"text-xs font-bold font-mono text-blue-600 bg-blue-50 px-2 py-0.5 rounded\">gold_dept_profitability (View)</span>\n              <h3 className=\"text-base font-semibold text-slate-900 tracking-tight mt-2\">Active Department Margin Contribution</h3>\n              <p className=\"text-[11px] text-slate-400 mt-0.5\">Simulated Gold aggregations computing net margins across hospital channels</p>\n            </div>\n\n            <div className=\"h-64 w-full\">\n              {pipelineMetrics?.goldAggregations?.departmentProfitability ? (\n                <ResponsiveContainer width=\"100%\" height=\"100%\">\n                  <BarChart data={pipelineMetrics.goldAggregations.departmentProfitability}>\n                    <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#f1f5f9\" vertical={false} />\n                    <XAxis dataKey=\"department\" stroke=\"#64748b\" fontSize={11} fontFamily=\"monospace\" tickLine={false} />\n                    <YAxis stroke=\"#64748b\" fontSize={10} fontFamily=\"monospace\" tickLine={false} />\n                    <Tooltip \n                      contentStyle={{ borderRadius: \'12px\', background: \'#0f172a\', border: \'none\', color: \'#fff\', fontSize: \'11px\', fontFamily: \'monospace\' }}\n                    />\n                    <Legend wrapperStyle={{ fontSize: \'11px\' }} />\n                    <Bar dataKey=\"revenue\" name=\"Total Revenue ($)\" fill=\"#3b82f6\" radius={[4, 4, 0, 0]} />\n                    <Bar dataKey=\"profit\" name=\"Net Margin ($)\" fill=\"#10b981\" radius={[4, 4, 0, 0]} />\n                  </BarChart>\n                </ResponsiveContainer>\n              ) : (\n                <div className=\"flex text-slate-300 justify-center h-full text-xs items-center\">Awaiting data...</div>\n              )}\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* Tab: Spark SQL Ingestion code snippets */}\n      {activeTab === \'code\' && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\n          \n          {/* Spark Read Python template */}\n          <div className=\"bg-slate-900 text-white rounded-2xl p-5 border border-slate-800 flex flex-col justify-between\">\n            <div>\n              <div className=\"flex items-center justify-between border-b border-slate-800 pb-3 mb-4\">\n                <span className=\"text-xs font-bold font-mono text-blue-400 flex items-center gap-1.5 focus:outline-none\">\n                  <Code2 className=\"h-3.5 w-3.5\" /> PySpark Data Frame Loader\n                </span>\n                <span className=\"text-[10px] text-slate-500 font-mono\">databricks_etl_read.py</span>\n              </div>\n              <pre className=\"text-[11px] font-mono leading-relaxed overflow-x-auto text-slate-200\">\n{`# 1. Establish Ingestion Paths from PulseStream Engine\ningress_base_url = \"${window.location.origin}/api/export/csv/\"\ntables = [\"patients\", \"appointments\", \"doctors\", \"transactions\"]\n\n# 2. Iterate and materialize as Delta Tables in Databricks\nfor table in tables:\n    raw_df = spark.read \\\\\n        .format(\"csv\") \\\\\n        .option(\"header\", \"true\") \\\\\n        .option(\"inferSchema\", \"true\") \\\\\n        .load(f\"{ingress_base_url}{table}\")\n        \n    # Write directly to raw Bronze Parquet Directory\n    raw_df.write \\\\\n        .format(\"delta\") \\\\\n        .mode(\"append\") \\\\\n        .save(f\"/mnt/pulse_healthcare/bronze/{table}\")\n        \nprint(\"Bronze appending ingestion run successfully executed.\")`}\n              </pre>\n            </div>\n            <div className=\"pt-4 border-t border-slate-800 mt-6 text-[10px] text-slate-500 flex items-center gap-2\">\n              <span className=\"px-1.5 py-0.5 bg-slate-800 rounded font-bold text-slate-400\">NOTE</span>\n              <span>Deploy onto a Databricks Job Cluster for automated periodic ingestion.</span>\n            </div>\n          </div>\n\n          {/* Delta Lake Merge Statement */}\n          <div className=\"bg-slate-900 text-white rounded-2xl p-5 border border-slate-800 flex flex-col justify-between\">\n            <div>\n              <div className=\"flex items-center justify-between border-b border-slate-800 pb-3 mb-4\">\n                <span className=\"text-xs font-bold font-mono text-emerald-400 flex items-center gap-1.5 focus:outline-none\">\n                  <Terminal className=\"h-3.5 w-3.5\" /> Silver Merge / UPSERT Statement\n                </span>\n                <span className=\"text-[10px] text-slate-500 font-mono\">transform_silver_merge.sql</span>\n              </div>\n              <pre className=\"text-[11px] font-mono leading-relaxed overflow-x-auto text-slate-200\">\n{`-- MERGE Bronze incoming records into production Silver Lake\n-- Deduplicate medical claims & consultation tuples dynamically\n\nMERGE INTO pulse_silver.transactions AS target\nUSING bronze_transactions_temp AS source\nON target.id = source.id\nWHEN MATCHED AND target.date < source.date THEN\n  UPDATE SET \n    target.amount = source.amount,\n    target.insuranceCoverage = source.insuranceCoverage,\n    target.paymentType = source.paymentType,\n    target.date = source.date\nWHEN NOT MATCHED THEN\n  INSERT (id, patientId, appointmentId, date, amount, type, insuranceCoverage, paymentType, department)\n  VALUES (source.id, source.patientId, source.appointmentId, source.date, source.amount, source.type, source.insuranceCoverage, source.paymentType, source.department);`}\n              </pre>\n            </div>\n            <div className=\"pt-4 border-t border-slate-800 mt-6 text-[10px] text-slate-500 flex items-center gap-2\">\n              <span className=\"px-1.5 py-0.5 bg-slate-800 rounded font-bold text-slate-400\">ACID</span>\n              <span>Guarantees idempotent transactions and stops double billing items.</span>\n            </div>\n          </div>\n\n        </div>\n      )}\n\n      {/* Tab: JSON / CSV export streams download list */}\n      {activeTab === \'exports\' && (\n        <div className=\"bg-white rounded-2xl p-5 border border-slate-100 shadow-sm space-y-6\">\n          <div>\n            <h3 className=\"text-base font-semibold text-slate-900 tracking-tight\">Structured Storage Exporters</h3>\n            <p className=\"text-[11px] text-slate-400 mt-0.5\">Use these live endpoints in Databricks or curl tasks to extract datasets directly</p>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\n            \n            {[\'patients\', \'appointments\', \'doctors\', \'departments\', \'transactions\'].map((tbl) => (\n              <div key={tbl} className=\"p-4 bg-slate-50 rounded-xl border border-slate-200 flex flex-col justify-between space-y-4\">\n                <div>\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"font-semibold text-sm capitalize text-slate-800\">{tbl} Lake Table</span>\n                    <Table className=\"h-3.5 w-3.5 text-slate-450\" />\n                  </div>\n                  <span className=\"text-[10px] text-slate-450 mt-1 block leading-normal\">\n                    Structured relational rows modeling active {tbl} schemas.\n                  </span>\n                </div>\n\n                <div className=\"flex items-center gap-2\">\n                  <a\n                    href={`/api/export/csv/${tbl}`}\n                    download\n                    className=\"flex-1 py-1.5 text-[10px] font-bold text-slate-700 bg-white border border-slate-250 rounded-lg hover:bg-slate-100 text-center flex items-center justify-center gap-1\"\n                  >\n                    <FileSpreadsheet className=\"h-3 w-3 text-emerald-600 shrink-0\" />\n                    CSV File\n                  </a>\n                  <a\n                    href={`/api/export/json/${tbl}`}\n                    download\n                    className=\"flex-1 py-1.5 text-[10px] font-bold text-slate-700 bg-white border border-slate-250 rounded-lg hover:bg-slate-100 text-center flex items-center justify-center gap-1\"\n                  >\n                    <FileJson className=\"h-3 w-3 text-amber-600 shrink-0\" />\n                    JSON File\n                  </a>\n                </div>\n              </div>\n            ))}\n\n          </div>\n        </div>\n      )}\n\n      {/* Tab: SQL query Sandbox playground */}\n      {activeTab === \'sandbox\' && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch\">\n          \n          {/* SQL Editor Terminal */}\n          <div className=\"lg:col-span-1 bg-slate-900 text-white rounded-2xl p-5 border border-slate-800 flex flex-col justify-between\">\n            <div className=\"space-y-4\">\n              <div className=\"flex items-center justify-between border-b border-slate-800 pb-3\">\n                <span className=\"text-xs font-bold font-mono text-slate-300 flex items-center gap-1.5\">\n                  <Terminal className=\"h-3.5 w-3.5\" /> Read-Only SQL Command\n                </span>\n                <span className=\"h-2 w-2 rounded-full bg-emerald-400\" />\n              </div>\n\n              {/* SQL Text Area block */}\n              <div>\n                <textarea\n                  value={sqlQuery}\n                  onChange={(e) => setSqlQuery(e.target.value)}\n                  className=\"w-full h-48 bg-slate-950 p-3.5 rounded-xl border border-slate-800 font-mono text-[11px] leading-relaxed text-slate-100 focus:outline-none focus:ring-1 focus:ring-blue-500/20\"\n                />\n              </div>\n\n              {/* Query presets selection */}\n              <div className=\"space-y-2\">\n                <span className=\"text-[10px] font-mono text-slate-500 uppercase block\">SQL Query Presets:</span>\n                <div className=\"space-y-1.5\">\n                  {sqlPresets.map((ps) => (\n                    <button\n                      key={ps.title}\n                      type=\"button\"\n                      onClick={() => setSqlQuery(ps.query)}\n                      className=\"w-full text-left p-2 rounded-lg bg-slate-850 hover:bg-slate-800 text-[10.5px] font-medium text-slate-300 border border-slate-800/80 hover:border-slate-800 block truncate transition-all\"\n                    >\n                      {ps.title}\n                    </button>\n                  ))}\n                </div>\n              </div>\n            </div>\n\n            <button\n              onClick={handleExecuteSql}\n              disabled={executingSql}\n              className=\"w-full bg-blue-600 hover:bg-blue-500 text-white font-semibold font-mono rounded-xl py-2.5 text-xs tracking-wider transition disabled:opacity-5 w-full mt-4 flex items-center justify-center gap-1.5\"\n            >\n              <Play className=\"h-3.5 w-3.5 fill-current shrink-0\" />\n              {executingSql ? \'Running Query planner...\' : \'EXECUTE SQL STATEMENT\'}\n            </button>\n          </div>\n\n          {/* Results Block */}\n          <div className=\"lg:col-span-2 bg-white rounded-2xl border border-slate-105 shadow-sm p-5 flex flex-col justify-between overflow-hidden\">\n            <div className=\"space-y-4 flex-1 flex flex-col overflow-hidden\">\n              <div className=\"flex items-center justify-between border-b border-slate-100 pb-3\">\n                <div>\n                  <h3 className=\"text-base font-semibold text-slate-900 leading-tight\">Relation Set Results</h3>\n                  <p className=\"text-[10px] text-slate-400\">Structured tables view resulting from selected schema query logic</p>\n                </div>\n                <span className=\"font-mono text-xs text-slate-400\">Rows count: {sqlResults.length}</span>\n              </div>\n\n              {/* Error or Results table */}\n              {sqlError ? (\n                <div className=\"p-4 bg-rose-50 border border-rose-100 text-rose-700 text-xs rounded-xl font-mono leading-relaxed mt-2\">\n                  {sqlError}\n                </div>\n              ) : sqlResults.length === 0 ? (\n                <div className=\"flex-1 flex flex-col justify-center items-center py-20 text-slate-350 text-xs font-mono space-y-2\">\n                  <Database className=\"h-8 w-8 text-slate-200\" />\n                  <span>Execute a SELECT query against database relations</span>\n                </div>\n              ) : (\n                <div className=\"flex-1 overflow-auto rounded-xl border border-slate-100 max-h-96\">\n                  <table className=\"w-full text-left border-collapse font-mono text-xs\">\n                    <thead>\n                      <tr className=\"bg-slate-50 border-b border-slate-100\">\n                        {sqlHeaders.map((hdr) => (\n                          <th key={hdr} className=\"px-4 py-2.5 font-bold text-slate-500 uppercase tracking-wider text-[10px]\">\n                            {hdr}\n                          </th>\n                        ))}\n                      </tr>\n                    </thead>\n                    <tbody className=\"divide-y divide-slate-50 text-slate-700 font-mono text-[11px]\">\n                      {sqlResults.map((row, idx) => (\n                        <tr key={idx} className=\"hover:bg-slate-50/40\">\n                          {sqlHeaders.map((hdr) => (\n                            <td key={hdr} className=\"px-4 py-2 text-slate-800 font-medium\">\n                              {row[hdr]?.toString() || \'NULL\'}\n                            </td>\n                          ))}\n                        </tr>\n                      ))}\n                    </tbody>\n                  </table>\n                </div>\n              )}\n            </div>\n\n            <div className=\"pt-4 border-t border-slate-100 text-[10px] text-slate-400 text-slate-450 block font-mono mt-4\">\n              Database models synced dynamically: patients, appointments, doctors, transactions, departments.\n            </div>\n          </div>\n\n        </div>\n      )}\n\n    </div>\n  );\n}\n"
    }
