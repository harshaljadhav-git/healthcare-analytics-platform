  file_change {
    absolute_path_uri: "file:///src/components/DashboardOverview.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { \n  Users, Calendar, CreditCard, Shield, Settings2, Sparkles, Activity, Clock, ThumbsUp, HelpCircle\n} from \'lucide-react\';\nimport { ResponsiveContainer, AreaChart, Area, XAxis, YAxis, Tooltip, CartesianGrid, BarChart, Bar, Legend, Cell } from \'recharts\';\nimport { motion } from \'motion/react\';\n\ninterface DashboardProps {\n  summary: any;\n  simStatus: any;\n  userRole: string;\n  onSpeedChange: (speed: string) => void;\n  onForceGenerate: () => void;\n  loading: boolean;\n}\n\nexport default function DashboardOverview({\n  summary,\n  simStatus,\n  userRole,\n  onSpeedChange,\n  onForceGenerate,\n  loading\n}: DashboardProps) {\n  const [showConfigHelp, setShowConfigHelp] = useState(false);\n\n  // Format currency\n  const formatCurrency = (val: number) => {\n    return new Intl.NumberFormat(\'en-US\', {\n      style: \'currency\',\n      currency: \'USD\',\n      maximumFractionDigits: 0\n    }).format(val);\n  };\n\n  const statCards = [\n    {\n      id: \"stat_patients\",\n      title: \"Total Tracked Patients\",\n      value: summary?.totalPatients?.toLocaleString() || \'-\',\n      desc: \"Captured across hospital network\",\n      icon: Users,\n      color: \"text-blue-500\",\n      bg: \"bg-blue-50\"\n    },\n    {\n      id: \"stat_inpatients\",\n      title: \"Active Inpatients\",\n      value: summary?.activePatients?.toLocaleString() || \'-\',\n      desc: \"Occupying ward beds currently\",\n      icon: Activity,\n      color: \"text-indigo-500\",\n      bg: \"bg-indigo-50\"\n    },\n    {\n      id: \"stat_appointments\",\n      title: \"Total Appointments\",\n      value: summary?.totalAppointments?.toLocaleString() || \'-\',\n      desc: \"Scheduled, completed & cancelled\",\n      icon: Calendar,\n      color: \"text-emerald-500\",\n      bg: \"bg-emerald-50\"\n    },\n    {\n      id: \"stat_revenue\",\n      title: \"Consolidated Revenue\",\n      value: summary?.revenueTotal ? formatCurrency(summary.revenueTotal) : \'-\',\n      desc: \"Consultation, labs & pharmacy services\",\n      icon: CreditCard,\n      color: \"text-amber-500\",\n      bg: \"bg-amber-50\"\n    }\n  ];\n\n  return (\n    <div className=\"space-y-6\">\n      \n      {/* Simulation Header Controller */}\n      <div className=\"bg-slate-900 text-white rounded-2xl p-5 md:p-6 shadow-md relative overflow-hidden border border-slate-800\">\n        <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_bottom_right,rgba(59,130,246,0.15),transparent)] pointer-events-none\" />\n        \n        <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 relative z-10\">\n          <div>\n            <div className=\"flex items-center gap-2\">\n              <span className=\"text-[10px] bg-blue-500/20 text-blue-400 font-mono tracking-widest px-2 py-0.5 rounded uppercase font-semibold\">\n                Simulated Environment Engine\n              </span>\n              <span className={`h-2 w-2 rounded-full ${simStatus?.speed === \'Pause\' ? \'bg-amber-500 animate-pulse\' : \'bg-emerald-400 animate-pulse\'}`} />\n            </div>\n            <h2 className=\"text-xl md:text-2xl font-bold tracking-tight mt-1 text-slate-100\">\n              Active Healthcare Operational Stream\n            </h2>\n            <p className=\"text-slate-400 text-xs md:text-sm mt-1\">\n              Currently feeding synthetic clinical and billing tuples into the Delta Ingest Broker.\n            </p>\n          </div>\n\n          {/* Controller selectors */}\n          <div className=\"flex flex-wrap items-center gap-2.5\">\n            <div className=\"bg-slate-850 p-1 rounded-xl border border-slate-800 flex items-center\">\n              {([\'Pause\', \'RealTime\', \'Fast\', \'Hyper\'] as const).map((sp) => (\n                <button\n                  key={sp}\n                  onClick={() => {\n                    if (userRole !== \'Admin\') {\n                      alert(\"Access Denied: Only users with the \'Admin\' role can alter the simulation speed.\");\n                      return;\n                    }\n                    onSpeedChange(sp);\n                  }}\n                  className={`px-3 py-1.5 rounded-lg text-xs font-semibold font-mono uppercase tracking-wider transition-all ${\n                    simStatus?.speed === sp\n                      ? \'bg-blue-600 text-white shadow-md\'\n                      : \'text-slate-400 hover:text-slate-200 hover:bg-slate-800\'\n                  }`}\n                >\n                  {sp === \'RealTime\' ? \'1x Live\' : sp === \'Fast\' ? \'10x Speed\' : sp === \'Hyper\' ? \'50x Speed\' : \'Paused\'}\n                </button>\n              ))}\n            </div>\n\n            <button\n              onClick={onForceGenerate}\n              disabled={loading}\n              className=\"bg-slate-800 hover:bg-slate-700 active:bg-slate-650 text-slate-200 border border-slate-700 px-4 py-2 rounded-xl text-xs font-semibold font-mono tracking-wider transition-all inline-flex items-center gap-1.5\"\n            >\n              <Sparkles className=\"h-3.5 w-3.5 text-amber-500\" />\n              Pulse Stream\n            </button>\n          </div>\n        </div>\n\n        {/* Live Simulation Statistics */}\n        <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4 mt-6 pt-5 border-t border-slate-800 relative z-10\">\n          <div>\n            <span className=\"text-slate-500 text-[10px] uppercase font-mono block\">Data Gen Cadence</span>\n            <span className=\"text-sm font-bold font-mono text-slate-250 mt-1 block\">\n              {simStatus?.speed === \'Pause\' ? \'N/A\' : (simStatus?.speed === \'RealTime\' ? \'Every 5 Mins\' : simStatus?.speed === \'Fast\' ? \'Every 15 Secs\' : \'Every 4 Secs\')}\n            </span>\n          </div>\n          <div>\n            <span className=\"text-slate-500 text-[10px] uppercase font-mono block\">Last Data Inbound</span>\n            <span className=\"text-sm font-bold font-mono text-slate-250 mt-1 block\">\n              {simStatus?.lastGenerated ? new Date(simStatus.lastGenerated).toLocaleTimeString() : \'N/A\'}\n            </span>\n          </div>\n          <div>\n            <span className=\"text-slate-500 text-[10px] uppercase font-mono block\">Total Dataset Rows</span>\n            <span className=\"text-sm font-bold font-mono text-slate-250 mt-1 block\">\n              {simStatus?.databaseMetrics ? (\n                (simStatus.databaseMetrics.patients + simStatus.databaseMetrics.appointments + simStatus.databaseMetrics.transactions).toLocaleString()\n              ) : \'-\'}\n            </span>\n          </div>\n          <div>\n            <span className=\"text-slate-500 text-[10px] uppercase font-mono block\">Ingress Quality Status</span>\n            <span className=\"text-sm font-bold font-mono text-emerald-400 mt-1 block flex items-center gap-1\">\n              <Shield className=\"h-3 w-3 shrink-0\" /> Stable (99.85%)\n            </span>\n          </div>\n        </div>\n      </div>\n\n      {/* Stats Cards Section */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\">\n        {statCards.map((card) => {\n          const Icon = card.icon;\n          return (\n            <div key={card.id} className=\"bg-white rounded-2xl p-5 border border-slate-100 shadow-sm flex items-start gap-4\">\n              <div className={`p-3 rounded-xl ${card.bg}`}>\n                <Icon className={`h-5 w-5 ${card.color}`} />\n              </div>\n              <div className=\"space-y-1\">\n                <span className=\"text-xs text-slate-500 block leading-tight font-medium\">{card.title}</span>\n                <span className=\"text-xl md:text-2xl font-bold font-mono text-slate-900 block leading-tight\">{card.value}</span>\n                <span className=\"text-[10px] text-slate-400 block\">{card.desc}</span>\n              </div>\n            </div>\n          );\n        })}\n      </div>\n\n      {/* Charts Section */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        \n        {/* Left: Interactive Revenue Trend Chart */}\n        <div className=\"bg-white rounded-2xl p-5 border border-slate-100 shadow-sm lg:col-span-2 space-y-4\">\n          <div className=\"flex items-center justify-between\">\n            <div>\n              <h3 className=\"text-base font-semibold text-slate-900 tracking-tight\">Consolidated Clinical Service Revenue</h3>\n              <p className=\"text-[11px] text-slate-400 mt-0.5\">Rolling operational billing streams captured at Bronze ingress</p>\n            </div>\n            <div className=\"flex items-center gap-4\">\n              <div className=\"flex items-center gap-1 text-xs\">\n                <span className=\"h-2 w-2 rounded-full bg-blue-500\" />\n                <span className=\"text-slate-500\">Live Yield</span>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"h-80 w-full\">\n            {summary?.appointmentTrends && summary.appointmentTrends.length > 0 ? (\n              <ResponsiveContainer width=\"100%\" height=\"100%\">\n                <AreaChart data={summary.appointmentTrends}>\n                  <defs>\n                    <linearGradient id=\"colorCount\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                      <stop offset=\"5%\" stopColor=\"#3b82f6\" stopOpacity={0.2}/>\n                      <stop offset=\"95%\" stopColor=\"#3b82f6\" stopOpacity={0}/>\n                    </linearGradient>\n                  </defs>\n                  <CartesianGrid strokeDasharray=\"3 3\" vertical={false} stroke=\"#f1f5f9\" />\n                  <XAxis \n                    dataKey=\"date\" \n                    stroke=\"#94a3b8\" \n                    fontSize={10} \n                    fontFamily=\"monospace\"\n                    tickLine={false}\n                    axisLine={false}\n                    tickFormatter={(date) => date.split(\'-\').slice(1).join(\'/\')}\n                  />\n                  <YAxis \n                    stroke=\"#94a3b8\" \n                    fontSize={10} \n                    fontFamily=\"monospace\"\n                    tickLine={false}\n                    axisLine={false}\n                    tickFormatter={(val) => `${val}`}\n                  />\n                  <Tooltip \n                    contentStyle={{ borderRadius: \'12px\', background: \'#0f172a\', border: \'none\', color: \'#fff\', fontSize: \'11px\', fontFamily: \'monospace\' }}\n                    labelFormatter={(label) => `Date: ${label}`}\n                  />\n                  <Area type=\"monotone\" dataKey=\"count\" name=\"Daily Appointments\" stroke=\"#3b82f6\" strokeWidth={2} fillOpacity={1} fill=\"url(#colorCount)\" />\n                </AreaChart>\n              </ResponsiveContainer>\n            ) : (\n              <div className=\"flex text-slate-350 justify-center items-center h-full text-xs\">Loading Live Simulation Data Streams...</div>\n            )}\n          </div>\n        </div>\n\n        {/* Right: Operational Hospital Status indicators & performance summary */}\n        <div className=\"bg-white rounded-2xl p-5 border border-slate-100 shadow-sm space-y-5\">\n          <div>\n            <h3 className=\"text-base font-semibold text-slate-900 tracking-tight\">System Performance Indicators</h3>\n            <p className=\"text-[11px] text-slate-400 mt-0.5\">Hospital network capacity benchmarks</p>\n          </div>\n\n          <div className=\"space-y-4\">\n            \n            {/* Average Patient Satisfaction Index */}\n            <div className=\"space-y-2\">\n              <div className=\"flex items-center justify-between text-xs\">\n                <span className=\"text-slate-600 font-medium flex items-center gap-1\">\n                  <ThumbsUp className=\"h-3.5 w-3.5 text-blue-500\" />\n                  Average Patient Satisfaction\n                </span>\n                <span className=\"font-mono font-bold text-slate-900\">{summary?.patientSatisfaction || \'4.5\'} / 5.0</span>\n              </div>\n              <div className=\"h-2 w-full bg-slate-100 rounded-full overflow-hidden\">\n                <div \n                  className=\"h-full bg-blue-500 rounded-full\" \n                  style={{ width: `${(summary?.patientSatisfaction || 4.5) * 20}%` }}\n                />\n              </div>\n              <span className=\"text-[10px] text-slate-400 block\">Calculated dynamically across 8 medical departments</span>\n            </div>\n\n            {/* General Doctor Workload Index */}\n            <div className=\"space-y-2\">\n              <div className=\"flex items-center justify-between text-xs\">\n                <span className=\"text-slate-600 font-medium flex items-center gap-1\">\n                  <Clock className=\"h-3.5 w-3.5 text-emerald-500\" />\n                  Avg Clinician Utilization\n                </span>\n                <span className=\"font-mono font-bold text-slate-900\">{summary?.avgDoctorUtilization || \'76\'}%</span>\n              </div>\n              <div className=\"h-2 w-full bg-slate-100 rounded-full overflow-hidden\">\n                <div \n                  className=\"h-full bg-emerald-500 rounded-full\" \n                  style={{ width: `${summary?.avgDoctorUtilization || 76}%` }}\n                />\n              </div>\n              <span className=\"text-[10px] text-slate-400 block\">Reflects active consulting hours vs. available rosters</span>\n            </div>\n\n            {/* Ingestion Stream Pipeline Status block */}\n            <div className=\"p-3.5 bg-slate-50 rounded-xl border border-slate-150 space-y-2\">\n              <span className=\"text-[10px] font-mono font-semibold uppercase tracking-wider text-slate-400 block\">Databricks-Ready Logs</span>\n              <div className=\"flex items-center justify-between text-xs\">\n                <span className=\"text-slate-600\">Bronze Table Count:</span>\n                <span className=\"font-mono font-semibold text-slate-800\">5 Tables</span>\n              </div>\n              <div className=\"flex items-center justify-between text-xs\">\n                <span className=\"text-slate-600\">Sync Schema compliance:</span>\n                <span className=\"font-mono font-semibold text-slate-800\">Parquet / Delta</span>\n              </div>\n              <div className=\"flex items-center justify-between text-xs\">\n                <span className=\"text-slate-600\">Daily Ingestion Growth:</span>\n                <span className=\"font-mono text-indigo-600 font-semibold\">+14.2 GB / day</span>\n              </div>\n            </div>\n\n          </div>\n        </div>\n\n      </div>\n\n    </div>\n  );\n}\n"
    }
