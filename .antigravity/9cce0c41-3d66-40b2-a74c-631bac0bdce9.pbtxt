    replacement_infos {
      original_chunk {
        target_content: "      {/* Tab: Spark SQL Ingestion code snippets */}\n      {activeTab === \'code\' && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\n          \n          {/* Spark Read Python template */}\n          <div className=\"bg-slate-900 text-white rounded-2xl p-5 border border-slate-800 flex flex-col justify-between\">\n            <div>\n              <div className=\"flex items-center justify-between border-b border-slate-800 pb-3 mb-4\">\n                <span className=\"text-xs font-bold font-mono text-blue-400 flex items-center gap-1.5 focus:outline-none\">\n                  <Code2 className=\"h-3.5 w-3.5\" /> PySpark Data Frame Loader\n                </span>\n                <span className=\"text-[10px] text-slate-500 font-mono\">databricks_etl_read.py</span>\n              </div>\n              <pre className=\"text-[11px] font-mono leading-relaxed overflow-x-auto text-slate-200\">\n{`# 1. Establish Ingestion Paths from PulseStream Engine\ningress_base_url = \"${window.location.origin}/api/export/csv/\"\ntables = [\"patients\", \"appointments\", \"doctors\", \"transactions\"]\n\n# 2. Iterate and materialize as Delta Tables in Databricks\nfor table in tables:\n    raw_df = spark.read \\\\\n        .format(\"csv\") \\\\\n        .option(\"header\", \"true\") \\\\\n        .option(\"inferSchema\", \"true\") \\\\\n        .load(f\"{ingress_base_url}{table}\")\n        \n    # Write directly to raw Bronze Parquet Directory\n    raw_df.write \\\\\n        .format(\"delta\") \\\\\n        .mode(\"append\") \\\\\n        .save(f\"/mnt/pulse_healthcare/bronze/{table}\")\n        \nprint(\"Bronze appending ingestion run successfully executed.\")`}\n              </pre>\n            </div>\n            <div className=\"pt-4 border-t border-slate-800 mt-6 text-[10px] text-slate-500 flex items-center gap-2\">\n              <span className=\"px-1.5 py-0.5 bg-slate-800 rounded font-bold text-slate-400\">NOTE</span>\n              <span>Deploy onto a Databricks Job Cluster for automated periodic ingestion.</span>\n            </div>\n          </div>\n\n          {/* Delta Lake Merge Statement */}\n          <div className=\"bg-slate-900 text-white rounded-2xl p-5 border border-slate-800 flex flex-col justify-between\">\n            <div>\n              <div className=\"flex items-center justify-between border-b border-slate-800 pb-3 mb-4\">\n                <span className=\"text-xs font-bold font-mono text-emerald-400 flex items-center gap-1.5 focus:outline-none\">\n                  <Terminal className=\"h-3.5 w-3.5\" /> Silver Merge / UPSERT Statement\n                </span>\n                <span className=\"text-[10px] text-slate-500 font-mono\">transform_silver_merge.sql</span>\n              </div>\n              <pre className=\"text-[11px] font-mono leading-relaxed overflow-x-auto text-slate-200\">\n{`-- MERGE Bronze incoming records into production Silver Lake\n-- Deduplicate medical claims & consultation tuples dynamically\n\nMERGE INTO pulse_silver.transactions AS target\nUSING bronze_transactions_temp AS source\nON target.id = source.id\nWHEN MATCHED AND target.date < source.date THEN\n  UPDATE SET \n    target.amount = source.amount,\n    target.insuranceCoverage = source.insuranceCoverage,\n    target.paymentType = source.paymentType,\n    target.date = source.date\nWHEN NOT MATCHED THEN\n  INSERT (id, patientId, appointmentId, date, amount, type, insuranceCoverage, paymentType, department)\n  VALUES (source.id, source.patientId, source.appointmentId, source.date, source.amount, source.type, source.insuranceCoverage, source.paymentType, source.department);`}\n              </pre>\n            </div>\n            <div className=\"pt-4 border-t border-slate-800 mt-6 text-[10px] text-slate-500 flex items-center gap-2\">\n              <span className=\"px-1.5 py-0.5 bg-slate-800 rounded font-bold text-slate-400\">ACID</span>\n              <span>Guarantees idempotent transactions and stops double billing items.</span>\n            </div>\n          </div>\n\n        </div>\n      )}\n\n      {/* Tab: JSON / CSV export streams download list */}\n      {activeTab === \'exports\' && (\n        <div className=\"bg-white rounded-2xl p-5 border border-slate-100 shadow-sm space-y-6\">\n          <div>\n            <h3 className=\"text-base font-semibold text-slate-900 tracking-tight\">Structured Storage Exporters</h3>\n            <p className=\"text-[11px] text-slate-400 mt-0.5\">Use these live endpoints in Databricks or curl tasks to extract datasets directly</p>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\n            \n            {[\'patients\', \'appointments\', \'doctors\', \'departments\', \'transactions\'].map((tbl) => (\n              <div key={tbl} className=\"p-4 bg-slate-50 rounded-xl border border-slate-200 flex flex-col justify-between space-y-4\">\n                <div>\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"font-semibold text-sm capitalize text-slate-800\">{tbl} Lake Table</span>\n                    <Table className=\"h-3.5 w-3.5 text-slate-450\" />\n                  </div>\n                  <span className=\"text-[10px] text-slate-450 mt-1 block leading-normal\">\n                    Structured relational rows modeling active {tbl} schemas.\n                  </span>\n                </div>\n\n                <div className=\"flex items-center gap-2\">\n                  <a\n                    href={`/api/export/csv/${tbl}`}\n                    download\n                    className=\"flex-1 py-1.5 text-[10px] font-bold text-slate-700 bg-white border border-slate-250 rounded-lg hover:bg-slate-100 text-center flex items-center justify-center gap-1\"\n                  >\n                    <FileSpreadsheet className=\"h-3 w-3 text-emerald-600 shrink-0\" />\n                    CSV File\n                  </a>\n                  <a\n                    href={`/api/export/json/${tbl}`}\n                    download\n                    className=\"flex-1 py-1.5 text-[10px] font-bold text-slate-700 bg-white border border-slate-250 rounded-lg hover:bg-slate-100 text-center flex items-center justify-center gap-1\"\n                  >\n                    <FileJson className=\"h-3 w-3 text-amber-600 shrink-0\" />\n                    JSON File\n                  </a>\n                </div>\n              </div>\n            ))}\n\n          </div>\n        </div>\n      )}\n\n      {/* Tab: SQL query Sandbox playground */}\n      {activeTab === \'sandbox\' && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch\">\n          \n          {/* SQL Editor Terminal */}\n          <div className=\"lg:col-span-1 bg-slate-900 text-white rounded-2xl p-5 border border-slate-800 flex flex-col justify-between\">\n            <div className=\"space-y-4\">\n              <div className=\"flex items-center justify-between border-b border-slate-800 pb-3\">\n                <span className=\"text-xs font-bold font-mono text-slate-300 flex items-center gap-1.5\">\n                  <Terminal className=\"h-3.5 w-3.5\" /> Read-Only SQL Command\n                </span>\n                <span className=\"h-2 w-2 rounded-full bg-emerald-400\" />\n              </div>\n\n              {/* SQL Text Area block */}\n              <div>\n                <textarea\n                  value={sqlQuery}\n                  onChange={(e) => setSqlQuery(e.target.value)}\n                  className=\"w-full h-48 bg-slate-950 p-3.5 rounded-xl border border-slate-800 font-mono text-[11px] leading-relaxed text-slate-100 focus:outline-none focus:ring-1 focus:ring-blue-500/20\"\n                />\n              </div>\n\n              {/* Query presets selection */}\n              <div className=\"space-y-2\">\n                <span className=\"text-[10px] font-mono text-slate-500 uppercase block\">SQL Query Presets:</span>\n                <div className=\"space-y-1.5\">\n                  {sqlPresets.map((ps) => (\n                    <button\n                      key={ps.title}\n                      type=\"button\"\n                      onClick={() => setSqlQuery(ps.query)}\n                      className=\"w-full text-left p-2 rounded-lg bg-slate-850 hover:bg-slate-800 text-[10.5px] font-medium text-slate-300 border border-slate-800/80 hover:border-slate-800 block truncate transition-all\"\n                    >\n                      {ps.title}\n                    </button>\n                  ))}\n                </div>\n              </div>\n            </div>\n\n            <button\n              onClick={handleExecuteSql}\n              disabled={executingSql}\n              className=\"w-full bg-blue-600 hover:bg-blue-500 text-white font-semibold font-mono rounded-xl py-2.5 text-xs tracking-wider transition disabled:opacity-5 w-full mt-4 flex items-center justify-center gap-1.5\"\n            >\n              <Play className=\"h-3.5 w-3.5 fill-current shrink-0\" />\n              {executingSql ? \'Running Query planner...\' : \'EXECUTE SQL STATEMENT\'}\n            </button>\n          </div>\n\n          {/* Results Block */}\n          <div className=\"lg:col-span-2 bg-white rounded-2xl border border-slate-105 shadow-sm p-5 flex flex-col justify-between overflow-hidden\">\n            <div className=\"space-y-4 flex-1 flex flex-col overflow-hidden\">\n              <div className=\"flex items-center justify-between border-b border-slate-100 pb-3\">\n                <div>\n                  <h3 className=\"text-base font-semibold text-slate-900 leading-tight\">Relation Set Results</h3>\n                  <p className=\"text-[10px] text-slate-400\">Structured tables view resulting from selected schema query logic</p>\n                </div>\n                <span className=\"font-mono text-xs text-slate-400\">Rows count: {sqlResults.length}</span>\n              </div>\n\n              {/* Error or Results table */}\n              {sqlError ? (\n                <div className=\"p-4 bg-rose-50 border border-rose-100 text-rose-700 text-xs rounded-xl font-mono leading-relaxed mt-2\">\n                  {sqlError}\n                </div>\n              ) : sqlResults.length === 0 ? (\n                <div className=\"flex-1 flex flex-col justify-center items-center py-20 text-slate-350 text-xs font-mono space-y-2\">\n                  <Database className=\"h-8 w-8 text-slate-200\" />\n                  <span>Execute a SELECT query against database relations</span>\n                </div>\n              ) : (\n                <div className=\"flex-1 overflow-auto rounded-xl border border-slate-100 max-h-96\">\n                  <table className=\"w-full text-left border-collapse font-mono text-xs\">\n                    <thead>\n                      <tr className=\"bg-slate-50 border-b border-slate-100\">\n                        {sqlHeaders.map((hdr) => (\n                          <th key={hdr} className=\"px-4 py-2.5 font-bold text-slate-500 uppercase tracking-wider text-[10px]\">\n                            {hdr}\n                          </th>\n                        ))}\n                      </tr>\n                    </thead>\n                    <tbody className=\"divide-y divide-slate-50 text-slate-700 font-mono text-[11px]\">\n                      {sqlResults.map((row, idx) => (\n                        <tr key={idx} className=\"hover:bg-slate-50/40\">\n                          {sqlHeaders.map((hdr) => (\n                            <td key={hdr} className=\"px-4 py-2 text-slate-800 font-medium\">\n                              {row[hdr]?.toString() || \'NULL\'}\n                            </td>\n                          ))}\n                        </tr>\n                      ))}\n                    </tbody>\n                  </table>\n                </div>\n              )}\n            </div>\n\n            <div className=\"pt-4 border-t border-slate-100 text-[10px] text-slate-400 text-slate-455 block font-mono mt-4\">\n              Database models synced dynamically: patients, appointments, doctors, transactions, departments.\n            </div>\n          </div>\n\n        </div>\n      )}"
        replacement_content: "      {/* Tab: Spark SQL Ingestion code snippets */}\n      {activeTab === \'code\' && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\n          \n          {/* Spark Read Python template */}\n          <div className=\"bg-[#141414] text-white rounded-none p-5 border border-[#141414] flex flex-col justify-between\">\n            <div>\n              <div className=\"flex items-center justify-between border-b border-white/20 pb-3 mb-4\">\n                <span className=\"text-xs font-bold font-mono text-[#0066FF] flex items-center gap-1.5 focus:outline-none\">\n                  <Code2 className=\"h-3.5 w-3.5\" /> PySpark Data Frame Loader\n                </span>\n                <span className=\"text-[10px] text-white/50 font-mono\">databricks_etl_read.py</span>\n              </div>\n              <pre className=\"text-[11px] font-mono leading-relaxed overflow-x-auto text-white/90\">\n{`# 1. Establish Ingestion Paths from PulseStream Engine\ningress_base_url = \"${window.location.origin}/api/export/csv/\"\ntables = [\"patients\", \"appointments\", \"doctors\", \"transactions\"]\n\n# 2. Iterate and materialize as Delta Tables in Databricks\nfor table in tables:\n    raw_df = spark.read \\\\\n        .format(\"csv\") \\\\\n        .option(\"header\", \"true\") \\\\\n        .option(\"inferSchema\", \"true\") \\\\\n        .load(f\"{ingress_base_url}{table}\")\n        \n    # Write directly to raw Bronze Parquet Directory\n    raw_df.write \\\\\n        .format(\"delta\") \\\\\n        .mode(\"append\") \\\\\n        .save(f\"/mnt/pulse_healthcare/bronze/{table}\")\n        \nprint(\"Bronze appending ingestion run successfully executed.\")`}\n              </pre>\n            </div>\n            <div className=\"pt-4 border-t border-white/10 mt-6 text-[10px] text-white/40 flex items-center gap-2 font-mono\">\n              <span className=\"px-1.5 py-0.5 bg-white/10 rounded-none font-bold text-white/80\">NOTE</span>\n              <span>Deploy onto a Databricks Job Cluster for automated periodic ingestion.</span>\n            </div>\n          </div>\n\n          {/* Delta Lake Merge Statement */}\n          <div className=\"bg-[#141414] text-white rounded-none p-5 border border-[#141414] flex flex-col justify-between\">\n            <div>\n              <div className=\"flex items-center justify-between border-b border-white/20 pb-3 mb-4\">\n                <span className=\"text-xs font-bold font-mono text-[#00CC66] flex items-center gap-1.5 focus:outline-none\">\n                  <Terminal className=\"h-3.5 w-3.5\" /> Silver Merge / UPSERT Statement\n                </span>\n                <span className=\"text-[10px] text-white/50 font-mono\">transform_silver_merge.sql</span>\n              </div>\n              <pre className=\"text-[11px] font-mono leading-relaxed overflow-x-auto text-white/90\">\n{`-- MERGE Bronze incoming records into production Silver Lake\n-- Deduplicate medical claims & consultation tuples dynamically\n\nMERGE INTO pulse_silver.transactions AS target\nUSING bronze_transactions_temp AS source\nON target.id = source.id\nWHEN MATCHED AND target.date < source.date THEN\n  UPDATE SET \n    target.amount = source.amount,\n    target.insuranceCoverage = source.insuranceCoverage,\n    target.paymentType = source.paymentType,\n    target.date = source.date\nWHEN NOT MATCHED THEN\n  INSERT (id, patientId, appointmentId, date, amount, type, insuranceCoverage, paymentType, department)\n  VALUES (source.id, source.patientId, source.appointmentId, source.date, source.amount, source.type, source.insuranceCoverage, source.paymentType, source.department);`}\n              </pre>\n            </div>\n            <div className=\"pt-4 border-t border-white/10 mt-6 text-[10px] text-white/40 flex items-center gap-2 font-mono\">\n              <span className=\"px-1.5 py-0.5 bg-white/10 rounded-none font-bold text-white/80\">ACID</span>\n              <span>Guarantees idempotent transactions and stops double billing items.</span>\n            </div>\n          </div>\n\n        </div>\n      )}\n\n      {/* Tab: JSON / CSV export streams download list */}\n      {activeTab === \'exports\' && (\n        <div className=\"bg-white rounded-none p-5 border border-[#141414] shadow-none space-y-6\">\n          <div>\n            <h3 className=\"text-xs font-bold text-[#141414] tracking-wider uppercase font-sans\">Structured Storage Exporters</h3>\n            <p className=\"text-[10px] font-mono text-[#141414]/60 uppercase mt-0.5\">Use these live endpoints in Databricks or curl tasks to extract datasets directly</p>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\n            \n            {[\'patients\', \'appointments\', \'doctors\', \'departments\', \'transactions\'].map((tbl) => (\n              <div key={tbl} className=\"p-4 bg-white rounded-none border border-[#141414] flex flex-col justify-between space-y-4\">\n                <div>\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"font-bold text-xs uppercase text-[#141414]\">{tbl} Lake Table</span>\n                    <Table className=\"h-3.5 w-3.5 text-[#141414]/50\" />\n                  </div>\n                  <span className=\"text-[10px] font-mono text-[#141414]/60 mt-1 block leading-normal uppercase\">\n                    Structured relational rows modeling active {tbl} schemas.\n                  </span>\n                </div>\n\n                <div className=\"flex items-center gap-2 font-mono\">\n                  <a\n                    href={`/api/export/csv/${tbl}`}\n                    download\n                    className=\"flex-1 py-1.5 text-[9px] font-bold text-[#141414] bg-[#F0EFEC] border border-[#141414] hover:bg-[#141414] hover:text-white transition-colors text-center uppercase\"\n                  >\n                    CSV\n                  </a>\n                  <a\n                    href={`/api/export/json/${tbl}`}\n                    download\n                    className=\"flex-1 py-1.5 text-[9px] font-bold text-[#141414] bg-[#F0EFEC] border border-[#141414] hover:bg-[#141414] hover:text-white transition-colors text-center uppercase\"\n                  >\n                    JSON\n                  </a>\n                </div>\n              </div>\n            ))}\n\n          </div>\n        </div>\n      )}\n\n      {/* Tab: SQL query Sandbox playground */}\n      {activeTab === \'sandbox\' && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch\">\n          \n          {/* SQL Editor Terminal */}\n          <div className=\"lg:col-span-1 bg-[#141414] text-white rounded-none p-5 border border-[#141414] flex flex-col justify-between\">\n            <div className=\"space-y-4\">\n              <div className=\"flex items-center justify-between border-b border-white/10 pb-3\">\n                <span className=\"text-xs font-bold font-mono text-white/80 flex items-center gap-1.5\">\n                  <Terminal className=\"h-3.5 w-3.5 text-[#0066FF]\" /> Read-Only SQL Command\n                </span>\n                <span className=\"h-2 w-2 rounded-none bg-[#00CC66]\" />\n              </div>\n\n              {/* SQL Text Area block */}\n              <div>\n                <textarea\n                  value={sqlQuery}\n                  onChange={(e) => setSqlQuery(e.target.value)}\n                  className=\"w-full h-48 bg-black/50 p-3.5 rounded-none border border-white/20 font-mono text-[11px] leading-relaxed text-white/95 focus:outline-none focus:border-white/40\"\n                />\n              </div>\n\n              {/* Query presets selection */}\n              <div className=\"space-y-2\">\n                <span className=\"text-[9px] font-mono text-white/40 uppercase block\">SQL Query Presets:</span>\n                <div className=\"space-y-1.5\">\n                  {sqlPresets.map((ps) => (\n                    <button\n                      key={ps.title}\n                      type=\"button\"\n                      onClick={() => setSqlQuery(ps.query)}\n                      className=\"w-full text-left p-2 rounded-none bg-white/5 hover:bg-white/10 text-[10px] font-mono text-white/80 border border-white/10 hover:border-white/20 block truncate transition-all cursor-pointer\"\n                    >\n                      {ps.title}\n                    </button>\n                  ))}\n                </div>\n              </div>\n            </div>\n\n            <button\n              onClick={handleExecuteSql}\n              disabled={executingSql}\n              className=\"w-full bg-[#0066FF] hover:bg-blue-500 text-white font-bold font-mono rounded-none py-2.5 text-xs tracking-wider transition disabled:opacity-30 w-full mt-4 flex items-center justify-center gap-1.5 cursor-pointer uppercase\"\n            >\n              <Play className=\"h-3.5 w-3.5 fill-current shrink-0\" />\n              {executingSql ? \'Running Query planner...\' : \'EXEC_QUERY\'}\n            </button>\n          </div>\n\n          {/* Results Block */}\n          <div className=\"lg:col-span-2 bg-white rounded-none border border-[#141414] shadow-none p-5 flex flex-col justify-between overflow-hidden\">\n            <div className=\"space-y-4 flex-1 flex flex-col overflow-hidden\">\n              <div className=\"flex items-center justify-between border-b border-[#141414]/15 pb-3\">\n                <div>\n                  <h3 className=\"text-xs font-bold text-[#141414] uppercase tracking-wider\">Relation Set Results</h3>\n                  <p className=\"text-[9px] font-mono text-[#141414]/60 uppercase\">Structured tables view resulting from selected schema query logic</p>\n                </div>\n                <span className=\"font-mono text-xs font-bold text-[#141414]\">Rows count: {sqlResults.length}</span>\n              </div>\n\n              {/* Error or Results table */}\n              {sqlError ? (\n                <div className=\"p-4 bg-[#FF3300]/10 border border-[#FF3300] text-[#FF3300] text-xs rounded-none font-mono leading-relaxed mt-2 uppercase\">\n                  {sqlError}\n                </div>\n              ) : sqlResults.length === 0 ? (\n                <div className=\"flex-1 flex flex-col justify-center items-center py-20 text-[#141414]/40 text-xs font-mono space-y-2\">\n                  <Database className=\"h-8 w-8 text-[#141414]/30\" />\n                  <span className=\"uppercase\">Execute a SELECT query against database relations</span>\n                </div>\n              ) : (\n                <div className=\"flex-1 overflow-auto rounded-none border border-[#141414]/20 max-h-96\">\n                  <table className=\"w-full text-left border-collapse font-mono text-xs\">\n                    <thead>\n                      <tr className=\"bg-[#F0EFEC] border-b border-[#141414]\">\n                        {sqlHeaders.map((hdr) => (\n                          <th key={hdr} className=\"px-4 py-2.5 font-bold text-[#141414] uppercase tracking-wider text-[10px]\">\n                            {hdr}\n                          </th>\n                        ))}\n                      </tr>\n                    </thead>\n                    <tbody className=\"divide-y divide-[#141414]/10 text-slate-700 font-mono text-[11px]\">\n                      {sqlResults.map((row, idx) => (\n                        <tr key={idx} className=\"hover:bg-[#F0EFEC]/40\">\n                          {sqlHeaders.map((hdr) => (\n                            <td key={hdr} className=\"px-4 py-2 text-[#141414] font-medium\">\n                              {row[hdr]?.toString() || \'NULL\'}\n                            </td>\n                          ))}\n                        </tr>\n                      ))}\n                    </tbody>\n                  </table>\n                </div>\n              )}\n            </div>\n\n            <div className=\"pt-4 border-t border-[#141414]/15 text-[9px] text-[#141414]/50 block font-mono mt-4 uppercase\">\n              Database models synced dynamically: patients, appointments, doctors, transactions, departments.\n            </div>\n          </div>\n\n        </div>\n      )}"
      }
      fuzzy_match: "      {/* Tab: Spark SQL Ingestion code snippets */}\n      {activeTab === \'code\' && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\n          \n          {/* Spark Read Python template */}\n          <div className=\"bg-slate-900 text-white rounded-2xl p-5 border border-slate-800 flex flex-col justify-between\">\n            <div>\n              <div className=\"flex items-center justify-between border-b border-slate-800 pb-3 mb-4\">\n                <span className=\"text-xs font-bold font-mono text-blue-400 flex items-center gap-1.5 focus:outline-none\">\n                  <Code2 className=\"h-3.5 w-3.5\" /> PySpark Data Frame Loader\n                </span>\n                <span className=\"text-[10px] text-slate-500 font-mono\">databricks_etl_read.py</span>\n              </div>\n              <pre className=\"text-[11px] font-mono leading-relaxed overflow-x-auto text-slate-200\">\n{`# 1. Establish Ingestion Paths from PulseStream Engine\ningress_base_url = \"${window.location.origin}/api/export/csv/\"\ntables = [\"patients\", \"appointments\", \"doctors\", \"transactions\"]\n\n# 2. Iterate and materialize as Delta Tables in Databricks\nfor table in tables:\n    raw_df = spark.read \\\\\n        .format(\"csv\") \\\\\n        .option(\"header\", \"true\") \\\\\n        .option(\"inferSchema\", \"true\") \\\\\n        .load(f\"{ingress_base_url}{table}\")\n        \n    # Write directly to raw Bronze Parquet Directory\n    raw_df.write \\\\\n        .format(\"delta\") \\\\\n        .mode(\"append\") \\\\\n        .save(f\"/mnt/pulse_healthcare/bronze/{table}\")\n        \nprint(\"Bronze appending ingestion run successfully executed.\")`}\n              </pre>\n            </div>\n            <div className=\"pt-4 border-t border-slate-800 mt-6 text-[10px] text-slate-500 flex items-center gap-2\">\n              <span className=\"px-1.5 py-0.5 bg-slate-800 rounded font-bold text-slate-400\">NOTE</span>\n              <span>Deploy onto a Databricks Job Cluster for automated periodic ingestion.</span>\n            </div>\n          </div>\n\n          {/* Delta Lake Merge Statement */}\n          <div className=\"bg-slate-900 text-white rounded-2xl p-5 border border-slate-800 flex flex-col justify-between\">\n            <div>\n              <div className=\"flex items-center justify-between border-b border-slate-800 pb-3 mb-4\">\n                <span className=\"text-xs font-bold font-mono text-emerald-400 flex items-center gap-1.5 focus:outline-none\">\n                  <Terminal className=\"h-3.5 w-3.5\" /> Silver Merge / UPSERT Statement\n                </span>\n                <span className=\"text-[10px] text-slate-500 font-mono\">transform_silver_merge.sql</span>\n              </div>\n              <pre className=\"text-[11px] font-mono leading-relaxed overflow-x-auto text-slate-200\">\n{`-- MERGE Bronze incoming records into production Silver Lake\n-- Deduplicate medical claims & consultation tuples dynamically\n\nMERGE INTO pulse_silver.transactions AS target\nUSING bronze_transactions_temp AS source\nON target.id = source.id\nWHEN MATCHED AND target.date < source.date THEN\n  UPDATE SET \n    target.amount = source.amount,\n    target.insuranceCoverage = source.insuranceCoverage,\n    target.paymentType = source.paymentType,\n    target.date = source.date\nWHEN NOT MATCHED THEN\n  INSERT (id, patientId, appointmentId, date, amount, type, insuranceCoverage, paymentType, department)\n  VALUES (source.id, source.patientId, source.appointmentId, source.date, source.amount, source.type, source.insuranceCoverage, source.paymentType, source.department);`}\n              </pre>\n            </div>\n            <div className=\"pt-4 border-t border-slate-800 mt-6 text-[10px] text-slate-500 flex items-center gap-2\">\n              <span className=\"px-1.5 py-0.5 bg-slate-800 rounded font-bold text-slate-400\">ACID</span>\n              <span>Guarantees idempotent transactions and stops double billing items.</span>\n            </div>\n          </div>\n\n        </div>\n      )}\n\n      {/* Tab: JSON / CSV export streams download list */}\n      {activeTab === \'exports\' && (\n        <div className=\"bg-white rounded-2xl p-5 border border-slate-100 shadow-sm space-y-6\">\n          <div>\n            <h3 className=\"text-base font-semibold text-slate-900 tracking-tight\">Structured Storage Exporters</h3>\n            <p className=\"text-[11px] text-slate-400 mt-0.5\">Use these live endpoints in Databricks or curl tasks to extract datasets directly</p>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\n            \n            {[\'patients\', \'appointments\', \'doctors\', \'departments\', \'transactions\'].map((tbl) => (\n              <div key={tbl} className=\"p-4 bg-slate-50 rounded-xl border border-slate-200 flex flex-col justify-between space-y-4\">\n                <div>\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"font-semibold text-sm capitalize text-slate-800\">{tbl} Lake Table</span>\n                    <Table className=\"h-3.5 w-3.5 text-slate-450\" />\n                  </div>\n                  <span className=\"text-[10px] text-slate-450 mt-1 block leading-normal\">\n                    Structured relational rows modeling active {tbl} schemas.\n                  </span>\n                </div>\n\n                <div className=\"flex items-center gap-2\">\n                  <a\n                    href={`/api/export/csv/${tbl}`}\n                    download\n                    className=\"flex-1 py-1.5 text-[10px] font-bold text-slate-700 bg-white border border-slate-250 rounded-lg hover:bg-slate-100 text-center flex items-center justify-center gap-1\"\n                  >\n                    <FileSpreadsheet className=\"h-3 w-3 text-emerald-600 shrink-0\" />\n                    CSV File\n                  </a>\n                  <a\n                    href={`/api/export/json/${tbl}`}\n                    download\n                    className=\"flex-1 py-1.5 text-[10px] font-bold text-slate-700 bg-white border border-slate-250 rounded-lg hover:bg-slate-100 text-center flex items-center justify-center gap-1\"\n                  >\n                    <FileJson className=\"h-3 w-3 text-amber-600 shrink-0\" />\n                    JSON File\n                  </a>\n                </div>\n              </div>\n            ))}\n\n          </div>\n        </div>\n      )}\n\n      {/* Tab: SQL query Sandbox playground */}\n      {activeTab === \'sandbox\' && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch\">\n          \n          {/* SQL Editor Terminal */}\n          <div className=\"lg:col-span-1 bg-slate-900 text-white rounded-2xl p-5 border border-slate-800 flex flex-col justify-between\">\n            <div className=\"space-y-4\">\n              <div className=\"flex items-center justify-between border-b border-slate-800 pb-3\">\n                <span className=\"text-xs font-bold font-mono text-slate-300 flex items-center gap-1.5\">\n                  <Terminal className=\"h-3.5 w-3.5\" /> Read-Only SQL Command\n                </span>\n                <span className=\"h-2 w-2 rounded-full bg-emerald-400\" />\n              </div>\n\n              {/* SQL Text Area block */}\n              <div>\n                <textarea\n                  value={sqlQuery}\n                  onChange={(e) => setSqlQuery(e.target.value)}\n                  className=\"w-full h-48 bg-slate-950 p-3.5 rounded-xl border border-slate-800 font-mono text-[11px] leading-relaxed text-slate-100 focus:outline-none focus:ring-1 focus:ring-blue-500/20\"\n                />\n              </div>\n\n              {/* Query presets selection */}\n              <div className=\"space-y-2\">\n                <span className=\"text-[10px] font-mono text-slate-500 uppercase block\">SQL Query Presets:</span>\n                <div className=\"space-y-1.5\">\n                  {sqlPresets.map((ps) => (\n                    <button\n                      key={ps.title}\n                      type=\"button\"\n                      onClick={() => setSqlQuery(ps.query)}\n                      className=\"w-full text-left p-2 rounded-lg bg-slate-850 hover:bg-slate-800 text-[10.5px] font-medium text-slate-300 border border-slate-800/80 hover:border-slate-800 block truncate transition-all\"\n                    >\n                      {ps.title}\n                    </button>\n                  ))}\n                </div>\n              </div>\n            </div>\n\n            <button\n              onClick={handleExecuteSql}\n              disabled={executingSql}\n              className=\"w-full bg-blue-600 hover:bg-blue-500 text-white font-semibold font-mono rounded-xl py-2.5 text-xs tracking-wider transition disabled:opacity-5 w-full mt-4 flex items-center justify-center gap-1.5\"\n            >\n              <Play className=\"h-3.5 w-3.5 fill-current shrink-0\" />\n              {executingSql ? \'Running Query planner...\' : \'EXECUTE SQL STATEMENT\'}\n            </button>\n          </div>\n\n          {/* Results Block */}\n          <div className=\"lg:col-span-2 bg-white rounded-2xl border border-slate-105 shadow-sm p-5 flex flex-col justify-between overflow-hidden\">\n            <div className=\"space-y-4 flex-1 flex flex-col overflow-hidden\">\n              <div className=\"flex items-center justify-between border-b border-slate-100 pb-3\">\n                <div>\n                  <h3 className=\"text-base font-semibold text-slate-900 leading-tight\">Relation Set Results</h3>\n                  <p className=\"text-[10px] text-slate-400\">Structured tables view resulting from selected schema query logic</p>\n                </div>\n                <span className=\"font-mono text-xs text-slate-400\">Rows count: {sqlResults.length}</span>\n              </div>\n\n              {/* Error or Results table */}\n              {sqlError ? (\n                <div className=\"p-4 bg-rose-50 border border-rose-100 text-rose-700 text-xs rounded-xl font-mono leading-relaxed mt-2\">\n                  {sqlError}\n                </div>\n              ) : sqlResults.length === 0 ? (\n                <div className=\"flex-1 flex flex-col justify-center items-center py-20 text-slate-350 text-xs font-mono space-y-2\">\n                  <Database className=\"h-8 w-8 text-slate-200\" />\n                  <span>Execute a SELECT query against database relations</span>\n                </div>\n              ) : (\n                <div className=\"flex-1 overflow-auto rounded-xl border border-slate-100 max-h-96\">\n                  <table className=\"w-full text-left border-collapse font-mono text-xs\">\n                    <thead>\n                      <tr className=\"bg-slate-50 border-b border-slate-100\">\n                        {sqlHeaders.map((hdr) => (\n                          <th key={hdr} className=\"px-4 py-2.5 font-bold text-slate-500 uppercase tracking-wider text-[10px]\">\n                            {hdr}\n                          </th>\n                        ))}\n                      </tr>\n                    </thead>\n                    <tbody className=\"divide-y divide-slate-50 text-slate-700 font-mono text-[11px]\">\n                      {sqlResults.map((row, idx) => (\n                        <tr key={idx} className=\"hover:bg-slate-50/40\">\n                          {sqlHeaders.map((hdr) => (\n                            <td key={hdr} className=\"px-4 py-2 text-slate-800 font-medium\">\n                              {row[hdr]?.toString() || \'NULL\'}\n                            </td>\n                          ))}\n                        </tr>\n                      ))}\n                    </tbody>\n                  </table>\n                </div>\n              )}\n            </div>\n\n            <div className=\"pt-4 border-t border-slate-100 text-[10px] text-slate-400 text-slate-450 block font-mono mt-4\">\n              Database models synced dynamically: patients, appointments, doctors, transactions, departments.\n            </div>\n          </div>\n\n        </div>\n      )}"
      edit_distance: 1
      rel_edit_distance: 8.404068E-5
      num_matches: 1
      is_non_exact: true
      use_global_match: true
    }
  }
}
