        target_content: "  return (\n    <div className=\"min-h-screen bg-slate-50 flex items-center justify-center p-4\">\n      <div className=\"w-full max-w-4xl bg-white rounded-3xl shadow-xl flex flex-col md:flex-row overflow-hidden border border-slate-100\">\n        \n        {/* Left Side: Branding and info */}\n        <div className=\"md:w-5/12 bg-slate-900 p-8 text-white flex flex-col justify-between relative overflow-hidden\">\n          <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(30,58,138,0.4),transparent)]\" />\n          \n          <div className=\"relative z-10\">\n            <div className=\"flex items-center gap-3 mb-8\">\n              <div className=\"p-2.5 bg-blue-600 rounded-xl shadow-lg shadow-blue-500/20\">\n                <HeartPulse className=\"h-6 w-6 text-white\" />\n              </div>\n              <div>\n                <span className=\"font-semibold text-lg tracking-tight block\">PulseStream</span>\n                <span className=\"text-[10px] text-slate-400 font-mono tracking-wider uppercase block\">Healthcare Simulation</span>\n              </div>\n            </div>\n            \n            <h1 className=\"text-2xl font-bold tracking-tight mb-4 leading-tight\">\n              Production-Grade Operations Data Engine\n            </h1>\n            <p className=\"text-slate-300 text-sm leading-relaxed mb-6\">\n              PulseStream simulates patient entries, diagnostics, appointments, and billing streams to populate Bronze, Silver, and Gold data lakes.\n            </p>\n          </div>\n \n          <div className=\"relative z-10 border-t border-slate-800 pt-6\">\n            <span className=\"text-xs text-slate-400 font-mono block mb-2 uppercase tracking-widest\">\n              Ingestion Simulation Stats\n            </span>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div>\n                <span className=\"text-xs text-slate-400 block\">Baseline Nodes</