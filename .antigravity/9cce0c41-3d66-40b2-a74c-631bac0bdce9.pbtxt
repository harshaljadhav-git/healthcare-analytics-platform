rics.goldAggregations.departmentProfitability}>\n                    <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#f1f5f9\" vertical={false} />\n                    <XAxis dataKey=\"department\" stroke=\"#64748b\" fontSize={11} fontFamily=\"monospace\" tickLine={false} />\n                    <YAxis stroke=\"#64748b\" fontSize={10} fontFamily=\"monospace\" tickLine={false} />\n                    <Tooltip \n                      contentStyle={{ borderRadius: \'12px\', background: \'#0f172a\', border: \'none\', color: \'#fff\', fontSize: \'11px\', fontFamily: \'monospace\' }}\n                    />\n                    <Legend wrapperStyle={{ fontSize: \'11px\' }} />\n                    <Bar dataKey=\"revenue\" name=\"Total Revenue ($)\" fill=\"#3b82f6\" radius={[4, 4, 0, 0]} />\n                    <Bar dataKey=\"profit\" name=\"Net Margin ($)\" fill=\"#10b981\" radius={[4, 4, 0, 0]} />\n                  </BarChart>\n                </ResponsiveContainer>\n              ) : (\n                <div className=\"flex text-slate-300 justify-center h-full text-xs items-center\">Awaiting data...</div>\n              )}\n            </div>\n          </div>\n        </div>"
