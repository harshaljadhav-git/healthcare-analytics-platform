          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          {/* Delta Lake Merge Statement */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          <div className=\"bg-slate-900 text-white rounded-2xl p-5 border border-slate-800 flex flex-col justify-between\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            <div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <div className=\"flex items-center justify-between border-b border-slate-800 pb-3 mb-4\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <span className=\"text-xs font-bold font-mono text-emerald-400 flex items-center gap-1.5 focus:outline-none\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  <Terminal className=\"h-3.5 w-3.5\" /> Silver Merge / UPSERT Statement"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                </span>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <span className=\"text-[10px] text-slate-500 font-mono\">transform_silver_merge.sql</span>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <pre className=\"text-[11px] font-mono leading-relaxed overflow-x-auto text-slate-200\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "{`-- MERGE Bronze incoming records into production Silver Lake"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "-- Deduplicate medical claims & consultation tuples dynamically"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "MERGE INTO pulse_silver.transactions AS target"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "USING bronze_transactions_temp AS source"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "ON target.id = source.id"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "WHEN MATCHED AND target.date < source.date THEN"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  UPDATE SET "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    target.amount = source.amount,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    target.insuranceCoverage = source.insuranceCoverage,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    target.paymentType = source.paymentType,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    target.date = source.date"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "WHEN NOT MATCHED THEN"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  INSERT (id, patientId, appointmentId, date, amount, type, insuranceCoverage, paymentType, department)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  VALUES (source.id, source.patientId, source.appointmentId, source.date, source.amount, source.type, source.insuranceCoverage, source.paymentType, source.department);`}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </pre>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            <div className=\"pt-4 border-t border-slate-800 mt-6 text-[10px] text-slate-500 flex items-center gap-2\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <span className=\"px-1.5 py-0.5 bg-slate-800 rounded font-bold text-slate-400\">ACID</span>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
