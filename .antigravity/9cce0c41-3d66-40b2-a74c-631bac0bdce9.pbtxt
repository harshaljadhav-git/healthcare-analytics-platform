  file_change {
    absolute_path_uri: "file:///src/components/FinanceReportPanel.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useEffect } from \'react\';\nimport { Search, Filter, RefreshCw, ChevronLeft, ChevronRight, CreditCard, Landmark, DollarSign, Receipt } from \'lucide-react\';\nimport { ResponsiveContainer, BarChart, Bar, XAxis, YAxis, Tooltip, CartesianGrid, Legend, Cell, PieChart, Pie } from \'recharts\';\nimport { motion } from \'motion/react\';\n\ninterface FinanceProps {\n  token: string;\n}\n\nexport default function FinanceReportPanel({ token }: FinanceProps) {\n  const [transactions, setTransactions] = useState<any[]>([]);\n  const [total, setTotal] = useState(0);\n  const [page, setPage] = useState(1);\n  const [limit, setLimit] = useState(10);\n  const [selectedType, setSelectedType] = useState(\'\');\n  const [selectedPayment, setSelectedPayment] = useState(\'\');\n  const [loading, setLoading] = useState(false);\n  const [analytics, setAnalytics] = useState<any>(null);\n\n  // Colors for Pie Charts\n  const COLORS = [\'#3b82f6\', \'#10b981\', \'#f59e0b\', \'#8b5cf6\', \'#ec4899\'];\n\n  const fetchTransactions = async () => {\n    setLoading(true);\n    try {\n      const url = new URL(\'/api/transactions\', window.location.origin);\n      url.searchParams.set(\'page\', page.toString());\n      url.searchParams.set(\'limit\', limit.toString());\n      if (selectedType) url.searchParams.set(\'type\', selectedType);\n      if (selectedPayment) url.searchParams.set(\'paymentType\', selectedPayment);\n\n      const res = await fetch(url.toString(), {\n        headers: { Authorization: `Bearer ${token}` }\n      });\n      const data = await res.json();\n      if (data && data.data) {\n        setTransactions(data.data);\n        setTotal(data.total);\n      }\n    } catch (err) {\n      console.error(\'Error fetching transactions:\', err);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const fetchAnalytics = async () => {\n    try {\n      const res = await fetch(\'/api/analytics/medallion\', {\n        headers: { Authorization: `Bearer ${token}` }\n      });\n      const data = await res.json();\n      if (data && data.goldAggregations) {\n        setAnalytics(data.goldAggregations);\n      }\n    } catch (err) {\n      console.error(\'Error fetching financial analytics:\', err);\n    }\n  };\n\n  useEffect(() => {\n    fetchTransactions();\n  }, [page, limit, selectedType, selectedPayment, token]);\n\n  useEffect(() => {\n    fetchAnalytics();\n  }, [token]);\n\n  const totalPages = Math.ceil(total / limit) || 1;\n\n  // Compute stats from analytics\n  const totalRevenue = transactions.reduce((sum, tx) => sum + tx.amount, 0);\n  const totalInsurancePayout = transactions.reduce((sum, tx) => sum + tx.insuranceCoverage, 0);\n\n  return (\n    <div className=\"space-y-6\">\n      \n      {/* Header and Counters */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4\">\n        <div>\n          <h2 className=\"text-xl font-bold tracking-tight text-slate-900\">Hospital Billing & Insurance Claims</h2>\n          <p className=\"text-xs text-slate-500 mt-0.5\">\n            Analysing clinical transaction lifecycles, insurer write-offs, and department sales metrics.\n          </p>\n        </div>\n        \n        {/* Quick summary totals */}\n        <div className=\"flex items-center gap-3\">\n          <div className=\"bg-white shadow-sm border border-slate-100 rounded-xl px-4 py-2 flex items-center gap-3\">\n            <div className=\"p-2 bg-blue-50 rounded-lg text-blue-500 font-bold font-mono\">\n              <DollarSign className=\"h-4 w-4 shrink-0\" />\n            </div>\n            <div>\n              <span className=\"text-[10px] text-slate-400 font-mono block uppercase font-medium\">Insurer Claims Paid</span>\n              <span className=\"text-sm font-bold font-mono text-slate-800\">\n                {analytics?.insuranceUtilization ? (\n                  `$${analytics.insuranceUtilization.reduce((sum: number, u: any) => sum + u.totalRevenue, 0).toLocaleString()}`\n                ) : \'-\'}\n              </span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Financial analytical models */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        \n        {/* Left: Insurance utilization pie */}\n        <div className=\"bg-white rounded-2xl p-5 border border-slate-100 shadow-sm space-y-4\">\n          <div>\n            <span className=\"text-xs font-bold font-mono text-indigo-650 bg-indigo-50 px-2 py-0.5 rounded\">gold_insurance_marketshare</span>\n            <h3 className=\"text-sm font-semibold text-slate-900 tracking-tight mt-2.5\">Insurance Provider Allocation</h3>\n            <p className=\"text-[10px] text-slate-400\">Insured coverage amounts vs client self payroll ratios</p>\n          </div>\n\n          <div className=\"h-56 w-full flex items-center justify-center\">\n            {analytics?.insuranceUtilization && analytics.insuranceUtilization.length > 0 ? (\n              <ResponsiveContainer width=\"100%\" height=\"100%\">\n                <PieChart>\n                  <Pie\n                    data={analytics.insuranceUtilization}\n                    cx=\"50%\"\n                    cy=\"50%\"\n                    innerRadius={60}\n                    outerRadius={80}\n                    paddingAngle={3}\n                    dataKey=\"totalRevenue\"\n                    nameKey=\"provider\"\n                  >\n                    {analytics.insuranceUtilization.map((entry: any, index: number) => (\n                      <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />\n                    ))}\n                  </Pie>\n                  <Tooltip formatter={(value) => `$${value.toLocaleString()}`} />\n                </PieChart>\n              </ResponsiveContainer>\n            ) : (\n              <span className=\"text-xs text-slate-300 font-mono\">Loading charts data...</span>\n            )}\n          </div>\n\n          {/* Table under pie */}\n          <div className=\"space-y-1.5 pt-3 border-t border-slate-100\">\n            {analytics?.insuranceUtilization?.map((item: any, idx: number) => (\n              <div key={item.provider} className=\"flex items-center justify-between text-[11px] font-mono\">\n                <div className=\"flex items-center gap-1.5\">\n                  <span className=\"h-2.5 w-2.5 rounded-full shrink-0\" style={{ backgroundColor: COLORS[idx % COLORS.length] }} />\n                  <span className=\"text-slate-600 font-sans font-medium\">{item.provider}</span>\n                </div>\n                <span className=\"font-bold text-slate-800\">${item.totalRevenue.toLocaleString()}</span>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* Right: Monthly dynamic revenue trends (Gold dimension) */}\n        <div className=\"bg-white rounded-2xl p-5 border border-slate-100 shadow-sm lg:col-span-2 space-y-4\">\n          <div>\n            <span className=\"text-xs font-bold font-mono text-emerald-650 bg-emerald-50 px-2 py-0.5 rounded\">gold_monthly_revenue_split</span>\n            <h3 className=\"text-sm font-semibold text-slate-900 tracking-tight mt-2.5\">Segmented Sales Development Trend</h3>\n            <p className=\"text-[10px] text-slate-400 font-sans\">Accumulated monthly gross splits including pharmacy items and ward consultations</p>\n          </div>\n\n          <div className=\"h-80 w-full\">\n            {analytics?.monthlyRevenueTrend && analytics.monthlyRevenueTrend.length > 0 ? (\n              <ResponsiveContainer width=\"100%\" height=\"100%\">\n                <BarChart data={analytics.monthlyRevenueTrend}>\n                  <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#f1f5f9\" vertical={false} />\n                  <XAxis \n                    dataKey=\"month\" \n                    stroke=\"#94a3b8\" \n                    fontSize={10} \n                    fontFamily=\"monospace\"\n                    tickLine={false}\n                    axisLine={false}\n                    tickFormatter={(m) => m.split(\'-\')[1] + \'/\' + m.split(\'-\')[0].substring(2)}\n                  />\n                  <YAxis \n                    stroke=\"#94a3b8\" \n                    fontSize={10} \n                    fontFamily=\"monospace\"\n                    tickLine={false}\n                    axisLine={false}\n                    tickFormatter={(val) => `$${val/1000}k`}\n                  />\n                  <Tooltip formatter={(val) => `$${val.toLocaleString()}`} />\n                  <Legend wrapperStyle={{ fontSize: \'10px\' }} />\n                  <Bar dataKey=\"consultation\" name=\"Consultations\" fill=\"#3b82f6\" stackId=\"a\" />\n                  <Bar dataKey=\"pharmacy\" name=\"Pharmacy\" fill=\"#10b981\" stackId=\"a\" />\n                  <Bar dataKey=\"lab\" name=\"Labs\" fill=\"#f59e0b\" stackId=\"a\" />\n                  <Bar dataKey=\"emergency\" name=\"Emergency\" fill=\"#8b5cf6\" stackId=\"a\" />\n                </BarChart>\n              </ResponsiveContainer>\n            ) : (\n              <span className=\"text-xs text-slate-300 font-mono\">Awaiting financial charts parsing...</span>\n            )}\n          </div>\n        </div>\n\n      </div>\n\n      {/* Query Filters */}\n      <div className=\"bg-white p-4 rounded-xl border border-slate-100 shadow-sm flex flex-wrap gap-2.5 items-center justify-between\">\n        <div className=\"flex flex-wrap items-center gap-2.5\">\n          \n          {/* Services types selector */}\n          <select\n            value={selectedType}\n            onChange={(e) => {\n              setSelectedType(e.target.value);\n              setPage(1);\n            }}\n            className=\"px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-xs text-slate-600/80 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 transition-all font-medium\"\n          >\n            <option value=\"\">All Services Items</option>\n            <option value=\"Consultation\">Consultation Charges</option>\n            <option value=\"Lab Fee\">Laboratory / Scans</option>\n            <option value=\"Pharmacy\">Pharmacy Dispensations</option>\n            <option value=\"Emergency Services\">Emergency Procedures</option>\n          </select>\n\n          {/* Payment Method */}\n          <select\n            value={selectedPayment}\n            onChange={(e) => {\n              setSelectedPayment(e.target.value);\n              setPage(1);\n            }}\n            className=\"px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-xs text-slate-600/80 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 transition-all font-medium\"\n          >\n            <option value=\"\">All Payment Types</option>\n            <option value=\"Insurance\">Insurance Provider Plan</option>\n            <option value=\"Cash\">Cash Payments</option>\n            <option value=\"Credit Card\">Credit Card Payments</option>\n            <option value=\"Debit Card\">Debit Card Payments</option>\n          </select>\n        </div>\n\n        <button\n          type=\"button\"\n          onClick={() => {\n            setSelectedType(\'\');\n            setSelectedPayment(\'\');\n            setPage(1);\n          }}\n          className=\"p-2 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-xl text-slate-500 hover:text-slate-705 transition flex items-center gap-1.5 text-xs font-semibold\"\n          title=\"Clear filters\"\n        >\n          <RefreshCw className=\"h-3.5 w-3.5 shrink-0\" />\n          Clear Filters\n        </button>\n      </div>\n\n      {/* Grid Table */}\n      <div className=\"bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden animate-fade-in\">\n        <div className=\"overflow-x-auto\">\n          <table className=\"w-full text-left border-collapse\">\n            <thead>\n              <tr className=\"bg-slate-50 border-b border-slate-100\">\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest animate-none\">Transaction ID</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Patient ID</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Service Division</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Gross Charge</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Insurance Co-Pay</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">User Out-of-pocket</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Settlement</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Billing Date</th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-slate-50 text-slate-700 text-xs font-mono\">\n              {loading ? (\n                <tr>\n                  <td colSpan={8} className=\"text-center py-10 font-mono text-slate-400\">\n                    Executing DB Query...\n                  </td>\n                </tr>\n              ) : transactions.length === 0 ? (\n                <tr>\n                  <td colSpan={8} className=\"text-center py-10 text-slate-400 animate-none\">\n                    No active synthetic database tuples match your filtration rules.\n                  </td>\n                </tr>\n              ) : (\n                transactions.map((tx) => {\n                  const outOfPocket = tx.amount - tx.insuranceCoverage;\n                  return (\n                    <tr key={tx.id} className=\"hover:bg-slate-50/50 transition-all\">\n                      <td className=\"px-5 py-3 text-slate-900 font-bold font-mono text-xs\">{tx.id}</td>\n                      <td className=\"px-5 py-3 text-blue-600 hover:underline cursor-pointer\">{tx.patientId}</td>\n                      <td className=\"px-5 py-3\">\n                        <span className={`px-2 py-0.5 rounded font-semibold text-[10px] ${\n                          tx.type === \'Consultation\' ? \'bg-blue-50 text-blue-700 border border-blue-100\' :\n                          tx.type === \'Lab Fee\' ? \'bg-amber-50 text-amber-700 border border-amber-100\' :\n                          tx.type === \'Pharmacy\' ? \'bg-emerald-50 text-emerald-700 border border-emerald-100\' :\n                          \'bg-indigo-50 text-indigo-700 border border-indigo-100\'\n                        }`}>\n                          {tx.type}\n                        </span>\n                      </td>\n                      <td className=\"px-5 py-3 text-slate-900 font-bold font-mono\">${tx.amount}</td>\n                      <td className=\"px-5 py-3 text-emerald-600 font-semibold font-mono\">${tx.insuranceCoverage}</td>\n                      <td className=\"px-5 py-3 text-rose-600 font-semibold font-mono\">${outOfPocket}</td>\n                      <td className=\"px-5 py-3 font-sans font-semibold text-slate-600\">{tx.paymentType}</td>\n                      <td className=\"px-5 py-3 text-slate-450 text-[11px] font-mono\">\n                        {new Date(tx.date).toLocaleDateString()}\n                      </td>\n                    </tr>\n                  );\n                })\n              )}\n            </tbody>\n          </table>\n        </div>\n\n        {/* Pagination Console */}\n        {totalPages > 1 && (\n          <div className=\"p-4 bg-slate-50 border-t border-slate-100 flex items-center justify-between text-xs text-slate-500\">\n            <span className=\"font-mono font-medium\">\n              Showing {((page - 1) * limit) + 1} to {Math.min(page * limit, total)} of <span className=\"font-semibold text-slate-800\">{total}</span> records\n            </span>\n            <div className=\"flex items-center gap-1\">\n              <button\n                type=\"button\"\n                onClick={() => setPage(p => Math.max(p - 1, 1))}\n                disabled={page === 1}\n                className=\"p-1.5 hover:bg-slate-150 border border-slate-200 bg-white rounded-lg disabled:opacity-50 transition\"\n              >\n                <ChevronLeft className=\"h-4 w-4 text-slate-600 animate-none\" />\n              </button>\n              <span className=\"px-3 py-1 font-mono font-bold text-slate-800 bg-white border border-slate-200 rounded-lg\">\n                Page {page} of {totalPages}\n              </span>\n              <button\n                type=\"button\"\n                onClick={() => setPage(p => Math.min(p + 1, totalPages))}\n                disabled={page === totalPages}\n                className=\"p-1.5 hover:bg-slate-150 border border-slate-200 bg-white rounded-lg disabled:opacity-50 transition\"\n              >\n                <ChevronRight className=\"h-4 w-4 text-slate-600 animate-none\" />\n              </button>\n            </div>\n          </div>\n        )}\n      </div>\n\n    </div>\n  );\n}\n"
    }
