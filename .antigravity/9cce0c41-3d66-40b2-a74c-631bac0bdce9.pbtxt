        }
        lines {
          text: "    const appointmentStatuses: (\'Scheduled\' | \'Completed\' | \'Cancelled\' | \'Rescheduled\')[] = [\'Completed\', \'Completed\', \'Completed\', \'Scheduled\', \'Cancelled\', \'Rescheduled\', \'Completed\', \'Completed\', \'Completed\', \'Completed\'];"
