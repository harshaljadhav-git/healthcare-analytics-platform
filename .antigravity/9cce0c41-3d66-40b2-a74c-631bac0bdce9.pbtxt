    instruction: "Stylise PatientsPanel component using strict high-contrast technical grid borders, flat inputs, and monospace fonts."
    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"space-y-6\">\n      \n      {/* Header and Counters */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4\">\n        <div>\n          <h2 className=\"text-xl font-bold tracking-tight text-slate-900\">Synthetic Ingress Register: Patients</h2>\n          <p className=\"text-xs text-slate-500 mt-0.5\">\n            Operational Patient Master Index (PMI) feed reflecting synthetic demographics.\n          </p>\n        </div>\n        \n        {/* Total stats */}\n        <div className=\"bg-white shrink-0 shadow-sm border border-slate-100 rounded-xl px-4 py-2 flex items-center gap-3\">\n          <div className=\"p-2 bg-rose-50 rounded-lg text-rose-500 font-bold font-mono\">\n            <Heart className=\"h-4 w-4 fill-current shrink-0\" />\n          </div>\n          <div>\n            <span className=\"text-[10px] text-slate-400 font-mono block uppercase\">Total Lake Size</span>\n            <span className=\"text-base font-bold font-mono text-slate-800\">{total.toLocaleString()} Patients</span>\n          </div>\n        </div>\n      </div>\n\n      {/* Query Filters */}\n      <div className=\"bg-white p-4 rounded-xl border border-slate-100 shadow-sm\">\n        <form onSubmit={handleSearchSubmit} className=\"flex flex-col md:flex-row md:items-center justify-between gap-3\">\n          \n          {/* Left search */}\n          <div className=\"relative flex-1\">\n            <input\n              type=\"text\"\n              placeholder=\"Search by Patient ID, Name...\"\n              value={search}\n              onChange={(e) => setSearch(e.target.value)}\n              className=\"w-full pl-9 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-xs text-slate-700/80 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 transition-all\"\n            />\n            <Search className=\"absolute left-3 top-2.5 h-3.5 w-3.5 text-slate-455\" />\n          </div>\n\n          {/* Filters */}\n          <div className=\"flex flex-wrap items-center gap-2.5\">\n            \n            {/* Category selection */}\n            <select\n              value={selectedCategory}\n              onChange={(e) => {\n                setSelectedCategory(e.target.value);\n                setPage(1);\n              }}\n              className=\"px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-xs text-slate-600/80 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 transition-all font-medium\"\n            >\n              <option value=\"\">All Care Categories</option>\n              <option value=\"Inpatient\">Inpatient</option>\n              <option value=\"Outpatient\">Outpatient</option>\n              <option value=\"ER\">Emergency Room (ER)</option>\n            </select>\n\n            {/* State selection */}\n            <select\n              value={selectedState}\n              onChange={(e) => {\n                setSelectedState(e.target.value);\n                setPage(1);\n              }}\n              className=\"px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-xs text-slate-600/80 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 transition-all font-medium\"\n            >\n              <option value=\"\">All States</option>\n              {statesList.map((st) => (\n                <option key={st} value={st}>{st}</option>\n              ))}\n            </select>\n\n            {/* Action buttons */}\n            <button\n              type=\"submit\"\n              className=\"px-3.5 py-2 bg-slate-900 border border-slate-800 text-white rounded-xl text-xs font-semibold hover:bg-slate-850 transition-all\"\n            >\n              Apply Filter\n            </button>\n\n            <button\n              type=\"button\"\n              onClick={() => {\n                setSearch(\'\');\n                setSelectedState(\'\');\n                setSelectedCategory(\'\');\n                setPage(1);\n              }}\n              className=\"p-2 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-xl text-slate-500 hover:text-slate-700 transition\"\n              title=\"Reset configuration\"\n            >\n              <RefreshCw className=\"h-3.5 w-3.5 shrink-0\" />\n            </button>\n          </div>\n\n        </form>\n      </div>\n\n      {/* Grid Table */}\n      <div className=\"bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden\">\n        <div className=\"overflow-x-auto\">\n          <table className=\"w-full text-left border-collapse\">\n            <thead>\n              <tr className=\"bg-slate-50 border-b border-slate-100\">\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Patient ID</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Full Name</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Age / Gender</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Blood Type</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Region</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Care Category</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Insurance Cover</th>\n                <th className=\"px-5 py-3.5 text-[10px] font-bold font-mono text-slate-450 uppercase tracking-widest\">Registration Date</th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-slate-50 text-slate-700 text-xs\">\n              {loading ? (\n                <tr>\n                  <td colSpan={8} className=\"text-center py-10 font-mono text-slate-400\">\n                    Executing DB Query...\n                  </td>\n                </tr>\n              ) : patients.length === 0 ? (\n                <tr>\n                  <td colSpan={8} className=\"text-center py-10 text-slate-400\">\n                    No active synthetic database tuples match your filtration rules.\n                  </td>\n                </tr>\n              ) : (\n                patients.map((pt) => (\n                  <tr key={pt.id} className=\"hover:bg-slate-50/50 transition-all font-mono\">\n                    <td className=\"px-5 py-3 text-slate-900 font-bold font-mono text-xs\">{pt.id}</td>\n                    <td className=\"px-5 py-3 font-sans font-semibold text-slate-800\">{pt.name}</td>\n                    <td className=\"px-5 py-3 font-sans text-slate-600\">\n                      {pt.age} yrs / <span className=\"text-slate-450\">{pt.gender}</span>\n                    </td>\n                    <td className=\"px-5 py-3\">\n                      <span className=\"px-2 py-0.5 bg-rose-50 text-rose-700 rounded font-bold text-[10px]\">\n                        {pt.bloodGroup}\n                      </span>\n                    </td>\n                    <td className=\"px-5 py-3 font-sans text-slate-600\">\n                      {pt.city}, <span className=\"font-mono font-medium text-slate-450\">{pt.state}</span>\n                    </td>\n                    <td className=\"px-5 py-3\">\n                      <span className={`px-2 py-0.5 rounded font-bold text-[10px] ${\n                        pt.category === \'Inpatient\' ? \'bg-indigo-100 text-indigo-700\' :\n                        pt.category === \'Outpatient\' ? \'bg-emerald-100 text-emerald-700\' :\n                        \'bg-amber-100 text-amber-700\'\n                      }`}>\n                        {pt.category}\n                      </span>\n                    </td>\n                    <td className=\"px-5 py-3 font-sans text-slate-600 font-medium\">\n                      {pt.insuranceProvider}\n                    </td>\n                    <td className=\"px-5 py-3 text-slate-450 font-mono text-[11px]\">\n                      {new Date(pt.registrationDate).toLocaleDateString()}\n                    </td>\n                  </tr>\n                ))\n              )}\n            </tbody>\n          </table>\n        </div>\n\n        {/* Pagination Console */}\n        {totalPages > 1 && (\n          <div className=\"p-4 bg-slate-50 border-t border-slate-100 flex items-center justify-between text-xs text-slate-500\">\n            <span className=\"font-mono font-medium\">\n              Showing {((page - 1) * limit) + 1} to {Math.min(page * limit, total)} of <span className=\"font-semibold text-slate-800\">{total}</span> records\n            </span>\n            <div className=\"flex items-center gap-1\">\n              <button\n                type=\"button\"\n                onClick={() => setPage(p => Math.max(p - 1, 1))}\n                disabled={page === 1}\n                className=\"p-1.5 hover:bg-slate-150 border border-slate-200 bg-white rounded-lg disabled:opacity-50 transition\"\n              >\n                <ChevronLeft className=\"h-4 w-4 text-slate-600\" />\n              </button>\n              <span className=\"px-3 py-1 font-mono font-bold text-slate-800 bg-white border border-slate-200 rounded-lg\">\n                Page {page} of {totalPages}\n              </span>\n              <button\n                type=\"button\"\n                onClick={() => setPage(p => Math.min(p + 1, totalPages))}\n                disabled={page === totalPages}\n                className=\"p-1.5 hover:bg-slate-150 border border-slate-200 bg-white rounded-lg disabled:opacity-50 transition\"\n              >\n                <ChevronRight className=\"h-4 w-4 text-slate-600\" />\n              </button>\n            </div>\n          </div>\n        )}\n      </div>"
        replacement_content: "  return (\n    <div className=\"space-y-6\">\n      \n      {/* Header and Counters */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4\">\n        <div>\n          <h2 className=\"text-xl font-black tracking-tighter text-[#141414] uppercase\">SYNTHETIC INGRESS REGISTER: PATIENTS</h2>\n          <p className=\"text-[10px] font-mono text-[#141414]/60 uppercase mt-0.5\">\n            Operational Patient Master Index (PMI) feed reflecting synthetic demographics.\n          </p>\n        </div>\n        \n        {/* Total stats */}\n        <div className=\"bg-white shrink-0 shadow-none border border-[#141414] rounded-none px-4 py-2 flex items-center gap-3\">\n          <div className=\"p-2 bg-[#F0EFEC] border border-[#141414] text-[#141414] font-bold font-mono\">\n            <Heart className=\"h-4 w-4 fill-current shrink-0 text-[#141414]\" />\n          </div>\n          <div>\n            <span className=\"text-[9px] text-[#141414]/50 font-mono block uppercase\">Total Lake Size</span>\n            <span className=\"text-sm font-black font-mono text-[#141414]\">{total.toLocaleString()} PATIENTS</span>\n          </div>\n        </div>\n      </div>\n\n      {/* Query Filters */}\n      <div className=\"bg-white p-4 rounded-none border border-[#141414] shadow-none\">\n        <form onSubmit={handleSearchSubmit} className=\"flex flex-col md:flex-row md:items-center justify-between gap-3\">\n          \n          {/* Left search */}\n          <div className=\"relative flex-1\">\n            <input\n              type=\"text\"\n              placeholder=\"Query patient details (ID, Name)...\"\n              value={search}\n              onChange={(e) => setSearch(e.target.value)}\n              className=\"w-full pl-9 pr-4 py-2 bg-white border border-[#141414] rounded-none text-xs font-mono text-[#141414] placeholder-[#141414]/40 focus:outline-none focus:ring-1 focus:ring-[#141414]\"\n            />\n            <Search className=\"absolute left-3 top-2.5 h-3.5 w-3.5 text-[#141414]/60\" />\n          </div>\n\n          {/* Filters */}\n          <div className=\"flex flex-wrap items-center gap-2.5\">\n            \n            {/* Category selection */}\n            <select\n              value={selectedCategory}\n              onChange={(e) => {\n                setSelectedCategory(e.target.value);\n                setPage(1);\n              }}\n              className=\"px-3 py-2 bg-white border border-[#141414] rounded-none text-xs text-[#141414] focus:outline-none focus:ring-1 focus:ring-[#141414] font-mono\"\n            >\n              <option value=\"\">All Care Categories</option>\n              <option value=\"Inpatient\">Inpatient</option>\n              <option value=\"Outpatient\">Outpatient</option>\n              <option value=\"ER\">Emergency Room (ER)</option>\n            </select>\n\n            {/* State selection */}\n            <select\n              value={selectedState}\n              onChange={(e) => {\n                setSelectedState(e.target.value);\n                setPage(1);\n              }}\n              className=\"px-3 py-2 bg-white border border-[#141414] rounded-none text-xs text-[#141414] focus:outline-none focus:ring-1 focus:ring-[#141414] font-mono\"\n            >\n              <option value=\"\">All States</option>\n              {statesList.map((st) => (\n                <option key={st} value={st}>{st}</option>\n              ))}\n            </select>\n\n            {/* Action buttons */}\n            <button\n              type=\"submit\"\n              className=\"px-4 py-2 bg-[#141414] text-white rounded-none text-xs font-bold hover:bg-[#333] transition-colors uppercase font-mono cursor-pointer\"\n            >\n              APPLY_FILTER\n            </button>\n\n            <button\n              type=\"button\"\n              onClick={() => {\n                setSearch(\'\');\n                setSelectedState(\'\');\n                setSelectedCategory(\'\');\n                setPage(1);\n              }}\n              className=\"p-2 bg-[#F0EFEC] hover:bg-[#141414] hover:text-white border border-[#141414] rounded-none text-[#141414] transition cursor-pointer\"\n              title=\"Reset configuration\"\n            >\n              <RefreshCw className=\"h-3.5 w-3.5 shrink-0\" />\n            </button>\n          </div>\n\n        </form>\n      </div>\n\n      {/* Grid Table */}\n      <div className=\"bg-white rounded-none border border-[#141414] shadow-none overflow-hidden\">\n        <div className=\"overflow-x-auto\">\n          <table className=\"w-full text-left border-collapse\">\n            <thead>\n              <tr className=\"bg-[#F0EFEC] border-b border-[#141414]\">\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Patient ID</th>\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Full Name</th>\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Age / Gender</th>\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Blood Type</th>\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Region</th>\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Care Category</th>\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Insurance Cover</th>\n                <th className=\"px-5 py-3 text-[10px] font-bold font-serif italic text-[#141414] uppercase tracking-wider\">Registration Date</th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-[#141414]/15 text-[#141414] text-xs\">\n              {loading ? (\n                <tr>\n                  <td colSpan={8} className=\"text-center py-12 font-mono text-[#141414]/65\">\n                    Executing Ingress Index Query...\n                  </td>\n                </tr>\n              ) : patients.length === 0 ? (\n                <tr>\n                  <td colSpan={8} className=\"text-center py-12 text-[#141414]/65 font-mono\">\n                    No active synthetic database tuples match your filtration rules.\n                  </td>\n                </tr>\n              ) : (\n                patients.map((pt) => (\n                  <tr key={pt.id} className=\"hover:bg-[#F0EFEC] transition-all font-mono\">\n                    <td className=\"px-5 py-3 text-[#141414] font-bold font-mono text-xs\">{pt.id}</td>\n                    <td className=\"px-5 py-3 font-sans font-bold text-[#141414] uppercase\">{pt.name}</td>\n                    <td className=\"px-5 py-3\">\n                      {pt.age} yrs / <span className=\"opacity-70\">{pt.gender}</span>\n                    </td>\n                    <td className=\"px-5 py-3\">\n                      <span className=\"px-1.5 py-0.5 bg-white text-[#141414] border border-[#141414] font-bold text-[10px]\">\n                        {pt.bloodGroup}\n                      </span>\n                    </td>\n                    <td className=\"px-5 py-3 font-sans text-[#141414]/80\">\n                      {pt.city}, <span className=\"font-mono font-bold opacity-70\">{pt.state}</span>\n                    </td>\n                    <td className=\"px-5 py-3\">\n                      <span className={`px-1.5 py-0.5 border border-[#141414] font-bold text-[9px] uppercase ${\n                        pt.category === \'Inpatient\' ? \'bg-[#0033CC] text-white\' :\n                        pt.category === \'Outpatient\' ? \'bg-[#00CC66]/20 text-[#141414]\' :\n                        \'bg-[#CC6600]/20 text-[#141414]\'\n                      }`}>\n                        {pt.category}\n                      </span>\n                    </td>\n                    <td className=\"px-5 py-3 font-sans text-[#141414]/80\">\n                      {pt.insuranceProvider}\n                    </td>\n                    <td className=\"px-5 py-3 text-[#141414]/60 font-mono text-[10px]\">\n                      {new Date(pt.registrationDate).toLocaleDateString()}\n                    </td>\n                  </tr>\n                ))\n              )}\n            </tbody>\n          </table>\n        </div>\n\n        {/* Pagination Console */}\n        {totalPages > 1 && (\n          <div className=\"p-4 bg-[#F0EFEC] border-t border-[#141414] flex items-center justify-between text-xs text-[#141414]\">\n            <span className=\"font-mono font-medium opacity-85\">\n              Showing {((page - 1) * limit) + 1} to {Math.min(page * limit, total)} of <span className=\"font-bold text-[#141414]\">{total}</span> records\n            </span>\n            <div className=\"flex items-center gap-1.5\">\n              <button\n                type=\"button\"\n                onClick={() => setPage(p => Math.max(p - 1, 1))}\n                disabled={page === 1}\n                className=\"p-1.5 hover:bg-[#141414] hover:text-white border border-[#141414] bg-white disabled:opacity-30 transition cursor-pointer\"\n              >\n                <ChevronLeft className=\"h-4 w-4\" />\n              </button>\n              <span className=\"px-3 py-1 font-mono font-bold text-[#141414] bg-white border border-[#141414]\">\n                Page {page} of {totalPages}\n              </span>\n              <button\n                type=\"button\"\n                onClick={() => setPage(p => Math.min(p + 1, totalPages))}\n                disabled={page === totalPages}\n                className=\"p-1.5 hover:bg-[#141414] hover:text-white border border-[#141414] bg-white disabled:opacity-30 transition cursor-pointer\"\n              >\n                <ChevronRight className=\"h-4 w-4\" />\n              </button>\n            </div>\n          </div>\n        )}\n      </div>"
      }
