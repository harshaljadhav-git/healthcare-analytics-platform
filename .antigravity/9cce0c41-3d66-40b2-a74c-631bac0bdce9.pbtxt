    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useEffect } from \'react\';\nimport { Shield, Sparkles, Activity, Clock, ThumbsUp, Star, Award, UserCheck } from \'lucide-react\';\nimport { motion } from \'motion/react\';\n\ninterface DoctorsProps {\n  token: string;\n}\n\nexport default function DoctorsPanel({ token }: DoctorsProps) {\n  const [doctors, setDoctors] = useState<any[]>([]);\n  const [loading, setLoading] = useState(false);\n\n  const fetchDoctors = async () => {\n    setLoading(true);\n    try {\n      const res = await fetch(\'/api/doctors\', {\n        headers: { Authorization: `Bearer ${token}` }\n      });\n      const data = await res.json();\n      if (data && data.data) {\n        setDoctors(data.data);\n      }\n    } catch (err) {\n      console.error(\'Error fetching doctors:\', err);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  useEffect(() => {\n    fetchDoctors();\n  }, [token]);\n\n  return (\n    <div className=\"space-y-6\">\n      \n      {/* Title */}\n      <div>\n        <h2 className=\"text-xl font-bold tracking-tight text-slate-900\">Synthetic Ingress Register: Medical Staff</h2>\n        <p className=\"text-xs text-slate-500 mt-0.5\">\n          Staff roster tracking active clinical physicians, board specialties, and capacity booking metrics.\n        </p>\n      </div>\n\n      {loading ? (\n        <div className=\"text-center py-20 text-slate-400 font-mono text-xs\">Querying clinician roster partitions...</div>\n      ) : doctors.length === 0 ? (\n        <div className=\"text-center py-20 text-slate-450 text-xs\">No physicians database details available.</div>\n      ) : (\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5\">\n          {doctors.map((doc) => {\n            // Simulated satisfaction rating based on doc ID hash\n            const rating = 4.3 + (parseInt(doc.id.replace(\'DR\', \'\')) % 8) * 0.1;\n            \n            return (\n              <div \n                key={doc.id} \n                className=\"bg-white rounded-2xl p-5 border border-slate-100 shadow-sm flex flex-col justify-between hover:shadow-md transition-all border-l-4 border-l-blue-500\"\n              >\n                <div className=\"space-y-4\">\n                  \n                  {/* Doctor Card header */}\n                  <div className=\"flex items-start justify-between\">\n                    <div>\n                      <span className=\"text-[10px] font-mono font-bold text-blue-600 bg-blue-50 px-2 py-0.5 rounded\">\n                        {doc.id} (Staff Node)\n                      </span>\n                      <h3 className=\"text-base font-bold text-slate-900 tracking-tight mt-1 px-0\">{doc.name}</h3>\n                      <span className=\"text-[11px] text-slate-400 font-semibold block\">{doc.department} Division</span>\n                    </div>\n                    \n                    {/* Badge */}\n                    <div className=\"p-2 bg-slate-50 rounded-xl border border-slate-100\">\n                      <UserCheck className=\"h-4.5 w-4.5 text-slate-500\" />\n                    </div>\n                  </div>\n\n                  {/* Attributes */}\n                  <div className=\"space-y-2 pt-3 border-t border-slate-50\">\n                    <div className=\"flex items-center justify-between text-xs\">\n                      <span className=\"text-slate-500 flex items-center gap-1\">\n                        <Award className=\"h-3.5 w-3.5 text-teal-600\" />\n                        Staff Experience:\n                      </span>\n                      <span className=\"font-semibold text-slate-800 font-mono\">{doc.experience} Years</span>\n                    </div>\n\n                    <div className=\"flex items-center justify-between text-xs\">\n                      <span className=\"text-slate-500 flex items-center gap-1\">\n                        <Star className=\"h-3.5 w-3.5 text-amber-500 fill-current\" />\n                        Patient Rating:\n                      </span>\n                      <span className=\"font-semibold text-slate-800 font-mono\">{rating.toFixed(1)} / 5.0</span>\n                    </div>\n\n                    <div className=\"flex items-center justify-between text-xs\">\n                      <span className=\"text-slate-500 flex items-center gap-1\">\n                        <Clock className=\"h-3.5 w-3.5 text-indigo-500 shrink-0\" />\n                        Network Utilization:\n                      </span>\n                      <span className=\"font-semibold text-slate-800 font-mono\">{doc.utilization}% Capacity</span>\n                    </div>\n                  </div>\n\n                  {/* Utilization Bar */}\n                  <div className=\"space-y-1\">\n                    <div className=\"h-1.5 w-full bg-slate-100 rounded-full overflow-hidden\">\n                      <div \n                        className={`h-full rounded-full ${\n                          doc.utilization > 85 ? \'bg-amber-500\' :\n                          doc.utilization > 70 ? \'bg-indigo-500\' :\n                          \'bg-emerald-500\'\n                        }`}\n                        style={{ width: `${doc.utilization}%` }}\n                      />\n                    </div>\n                  </div>\n\n                </div>\n\n                <div className=\"flex items-center justify-between border-t border-slate-50 pt-3 mt-4 text-[11px]\">\n                  <span className=\"text-slate-405 font-mono\">Core Consul Rate:</span>\n                  <span className=\"font-bold text-slate-900 font-mono\">${doc.consultationFee} / session</span>\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      )}\n\n    </div>\n  );\n}\n"
    }
