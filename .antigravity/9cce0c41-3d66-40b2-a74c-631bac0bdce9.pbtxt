    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"space-y-6\">\n      \n      {/* Title */}\n      <div>\n        <h2 className=\"text-xl font-bold tracking-tight text-slate-900\">Databricks Data Lake Integration Dashboard</h2>\n        <p className=\"text-xs text-slate-500 mt-0.5\">\n          Orchestrate Medallion (Bronze/Silver/Gold) ingestion pipelines, generate Spark workloads, and query structured lakes.\n        </p>\n      </div>\n\n      {/* Tabs */}\n      <div className=\"border-b border-slate-100 flex items-center gap-1\">\n        <button\n          onClick={() => setActiveTab(\'visualizer\')}\n          className={`px-4 py-2 text-xs font-semibold tracking-wide border-b-2 transition-all ${\n            activeTab === \'visualizer\'\n              ? \'border-blue-600 text-blue-600\'\n              : \'border-transparent text-slate-500 hover:text-slate-800\'\n          }`}\n        >\n          Medallion Pipeline Visualizer\n        </button>\n        <button\n          onClick={() => setActiveTab(\'code\')}\n          className={`px-4 py-2 text-xs font-semibold tracking-wide border-b-2 transition-all ${\n            activeTab === \'code\'\n              ? \'border-blue-600 text-blue-600\'\n              : \'border-transparent text-slate-500 hover:text-slate-800\'\n          }`}\n        >\n          Databricks Spark ETL Templates\n        </button>\n        <button\n          onClick={() => setActiveTab(\'exports\')}\n          className={`px-4 py-2 text-xs font-semibold tracking-wide border-b-2 transition-all ${\n            activeTab === \'exports\'\n              ? \'border-blue-600 text-blue-600\'\n              : \'border-transparent text-slate-500 hover:text-slate-800\'\n          }`}\n        >\n          Data Lake Ingestion Endpoints (CSV/JSON)\n        </button>\n        <button\n          onClick={() => {\n            setActiveTab(\'sandbox\');\n            if (sqlResults.length === 0) handleExecuteSql();\n          }}\n          className={`px-4 py-2 text-xs font-semibold tracking-wide border-b-2 transition-all ${\n            activeTab === \'sandbox\'\n              ? \'border-blue-600 text-blue-600\'\n              : \'border-transparent text-slate-500 hover:text-slate-800\'\n          }`}\n        >\n          Interactive SQL Query Sandbox\n        </button>\n      </div>\n\n      {/* Tab: Visualizer */}\n      {activeTab === \'visualizer\' && (\n        <div className=\"space-y-6\">\n          <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-4 items-stretch\">\n            \n            {/* Bronze Node */}"
