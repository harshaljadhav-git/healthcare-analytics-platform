            </div>\n              <div className=\"border-t border-slate-50 pt-4 mt-6\">\n                <span className=\"text-[10px] text-slate-400 font-mono block\">STORAGE LOCATION:</span>\n                <span className=\"text-xs font-mono font-medium text-slate-650 mt-0.5 block\">mnt/pulse/bronze/db/</span>\n              </div>\n            </div>\n\n            {/* Silver Node */}\n            <div className=\"bg-white rounded-2xl p-5 border border-slate-100 shadow-sm flex flex-col justify-between relative\">\n              <div className=\"absolute -left-3 top-[50%] bg-white p-1 rounded-full border border-slate-100 hidden lg:block\">\n                <ArrowRight className=\"h-4 w-4 text-slate-355\" />\n              </div>\n              <div>\n                <div className=\"flex items-center justify-between\">\n                  <span className=\"text-xs font-bold font-mono text-slate-700 bg-slate-100 px-2 py-0.5 rounded\">\n                    Silver Stage (Cleaned)\n                  </span>\n                  <CheckCircle className=\"h-4 w-4 text-slate-500\" />\n                </div>\n                <h3 className=\"text-base font-bold text-slate-800 mt-3\">Sanitized Dimensional Models</h3>\n                <p className=\"text-xs text-slate-500 mt-1\">\n                  Applies strict schema validation, datetime formatting, deduplication, and types coercion. Implements strict GDPR audit boundaries.\n                </p>\n\n                {/* KPI block */}\n                <div className=\"mt-5 space-y-2.5\">\n                  <div className=\"flex items-center justify-between text-xs font-mono\">\n                    <span className=\"text-slate-500\">Schema Pass Rate:</span>\n                    <span className=\"text-emerald-600 font-bold\">{pipelineMetrics?.silverCleanPercentage || \'99.85\'}%</span>\n                  </div>\n                  <div className=\"flex items-center justify-between text-xs font-mono\">\n                    <span className=\"text-slate-500\">Index Partitions:</span>\n                    <span className=\"text-slate-850 font-bold\">12 Active</span>\n                  </div>\n                  <div className=\"flex items-center justify-between text-xs font-mono\">\n                    <span className=\"text-slate-500\">Records Parsed:</span>\n                    <span className=\"text-slate-850 font-bold\">{pipelineMetrics?.silverRecordsProcessed?.toLocaleString() || \'-\'} rows</span>\n                  </div>\n                </div>\n              </div>\n              <div className=\"border-t border-slate-50 pt-4 mt-6\">\n                <span className=\"text-[10px] text-slate-400 font-mono block\">STORAGE ENFORCE METHOD:</span>\n                <span className=\"text-xs font-mono font-medium text-slate-650 mt-0.5 block\">Delta ACID Transactions</span>\n              </div>\n            </div>\n\n            {/* Gold Node */}\n            <div className=\"bg-slate-900 rounded-2xl p-5 border border-slate-800 text-white shadow-md flex flex-col justify-between relative\">\n              <div className=\"absolute -left-3 top-[50%] bg-slate-900 p-1 rounded-full border border-slate-800 hidden lg:block\">\n                <ArrowRight className=\"h-4 w-4 text-slate-655\" />\n              </div>\n              <div>\n                <div className=\"flex items-center justify-between\">\n                  <span className=\"text-xs font-bold font-mono text-amber-400 bg-amber-500/20 px-2 py-0.5 rounded\">\n                    Gold Stage (Analytics)\n                  </span>\n                  <Database className=\"h-4 w-4 text-amber-400\" />\n                </div>\n                <h3 className=\"text-base font-bold text-white mt-3\">Downstream Reporting Hub</h3>\n                <p className=\"text-xs text-slate-400 mt-1\">\n                  High-leverage aggregate business reporting tables. Materialized delta structures optimised for business intelligence and dashboards.\n     