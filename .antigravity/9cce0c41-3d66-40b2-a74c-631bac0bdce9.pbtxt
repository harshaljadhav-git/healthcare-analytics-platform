        }
        lines {
          text: "          "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          {/* Spark Read Python template */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          <div className=\"bg-slate-900 text-white rounded-2xl p-5 border border-slate-800 flex flex-col justify-between\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            <div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <div className=\"flex items-center justify-between border-b border-slate-800 pb-3 mb-4\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <span className=\"text-xs font-bold font-mono text-blue-400 flex items-center gap-1.5 focus:outline-none\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  <Code2 className=\"h-3.5 w-3.5\" /> PySpark Data Frame Loader"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                </span>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <span className=\"text-[10px] text-slate-500 font-mono\">databricks_etl_read.py</span>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <pre className=\"text-[11px] font-mono leading-relaxed overflow-x-auto text-slate-200\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "{`# 1. Establish Ingestion Paths from PulseStream Engine"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "ingress_base_url = \"${window.location.origin}/api/export/csv/\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "tables = [\"patients\", \"appointments\", \"doctors\", \"transactions\"]"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "# 2. Iterate and materialize as Delta Tables in Databricks"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "for table in tables:"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    raw_df = spark.read \\\\"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .format(\"csv\") \\\\"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .option(\"header\", \"true\") \\\\"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .option(\"inferSchema\", \"true\") \\\\"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .load(f\"{ingress_base_url}{table}\")"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    # Write directly to raw Bronze Parquet Directory"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    raw_df.write \\\\"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .format(\"delta\") \\\\"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .mode(\"append\") \\\\"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        .save(f\"/mnt/pulse_healthcare/bronze/{table}\")"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "print(\"Bronze appending ingestion run successfully executed.\")`}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </pre>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            <div className=\"pt-4 border-t border-slate-800 mt-6 text-[10px] text-slate-500 flex items-center gap-2\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <span className=\"px-1.5 py-0.5 bg-slate-800 rounded font-bold text-slate-400\">NOTE</span>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <span>Deploy onto a Databricks Job Cluster for automated periodic ingestion.</span>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
