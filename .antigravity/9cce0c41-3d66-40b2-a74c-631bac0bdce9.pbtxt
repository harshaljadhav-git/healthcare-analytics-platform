          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "{`-- MERGE Bronze incoming records into production Silver Lake"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "-- Deduplicate medical claims & consultation tuples dynamically"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "MERGE INTO pulse_silver.transactions AS target"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "USING bronze_transactions_temp AS source"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "ON target.id = source.id"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "WHEN MATCHED AND target.date < source.date THEN"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  UPDATE SET "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    target.amount = source.amount,"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    target.insuranceCoverage = source.insuranceCoverage,"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    target.paymentType = source.paymentType,"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    target.date = source.date"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "WHEN NOT MATCHED THEN"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  INSERT (id, patientId, appointmentId, date, amount, type, insuranceCoverage, paymentType, department)"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  VALUES (source.id, source.patientId, source.appointmentId, source.date, source.amount, source.type, source.insuranceCoverage, source.paymentType, source.department);`}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              </pre>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
